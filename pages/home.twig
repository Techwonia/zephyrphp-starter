{% extends "layouts/base.twig" %}

{% block title %}Welcome to {{ config('app.name', 'ZephyrPHP') }}{% endblock %}

{% block content %}
<div class="hero">
    <div class="container">
        <div class="hero-content">
            <h1 class="hero-title">
                <span class="gradient-text">{{ config('app.name', 'ZephyrPHP') }}</span>
            </h1>
            <p class="hero-subtitle">Your site is ready. Sign in to manage content.</p>

            <div class="cta-buttons">
                <a href="/login" class="btn btn-primary">
                    Sign In
                </a>
                <a href="/register" class="btn btn-secondary">
                    Create Account
                </a>
            </div>
        </div>
    </div>
</div>
{% endblock %}
