{% extends "layouts/base.twig" %}

{% block title %}Welcome to ZephyrPHP{% endblock %}

{% block content %}
<div class="hero">
    <div class="container">
        <div class="hero-content">
            <h1 class="hero-title">
                <span class="gradient-text">ZephyrPHP</span>
            </h1>
            <p class="hero-subtitle">Light as a breeze, fast as the wind.</p>
            <p class="version-badge">v0.2.1</p>

            <div class="cta-buttons">
                <a href="https://zephyrphp.com/docs" class="btn btn-primary" target="_blank">
                    Documentation
                </a>
                <a href="https://github.com/Techwonia/zephyrphp" class="btn btn-secondary" target="_blank">
                    GitHub
                </a>
            </div>
        </div>
    </div>
</div>
{% endblock %}
