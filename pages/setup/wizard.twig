<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Setup — ZephyrPHP</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style nonce="{{ csp_nonce() }}">
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --bg: #0a0a0a;
            --bg-card: #111111;
            --bg-input: #1a1a1a;
            --border: rgba(255,255,255,0.08);
            --border-focus: rgba(6,182,212,0.5);
            --text: #ededed;
            --text-2: #888888;
            --text-3: #555555;
            --primary: #06b6d4;
            --primary-hover: #22d3ee;
            --success: #22c55e;
            --error: #ef4444;
            --info: #3b82f6;
            --radius: 12px;
            --radius-sm: 8px;
            --font: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        }

        body {
            font-family: var(--font);
            background: var(--bg);
            color: var(--text);
            line-height: 1.5;
            min-height: 100vh;
        }

        /* ── Split Layout ── */
        .setup-layout {
            display: grid;
            grid-template-columns: 2fr 5fr;
            min-height: 100vh;
        }

        /* ── Left Panel — Info ── */
        .setup-sidebar {
            position: relative;
            padding: 48px 32px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            border-right: 1px solid var(--border);
            overflow: hidden;
        }

        /* Grid pattern background */
        .setup-sidebar::before {
            content: '';
            position: absolute;
            inset: 0;
            background-image:
                linear-gradient(var(--border) 1px, transparent 1px),
                linear-gradient(90deg, var(--border) 1px, transparent 1px);
            background-size: 40px 40px;
            opacity: 0.5;
        }

        /* Gradient overlay */
        .setup-sidebar::after {
            content: '';
            position: absolute;
            inset: 0;
            background: radial-gradient(ellipse at 30% 20%, rgba(6,182,212,0.08), transparent 70%);
        }

        .sidebar-content {
            position: relative;
            z-index: 1;
        }

        .sidebar-logo {
            font-size: 1.5rem;
            font-weight: 800;
            letter-spacing: -0.03em;
            margin-bottom: 8px;
        }

        .sidebar-tagline {
            color: var(--text-2);
            font-size: 0.875rem;
            margin-bottom: 48px;
        }

        /* Step indicators in sidebar */
        .sidebar-steps {
            list-style: none;
            display: flex;
            flex-direction: column;
            gap: 0;
        }

        .sidebar-step {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 14px 0;
            font-size: 0.875rem;
            color: var(--text-3);
            transition: color 0.2s;
        }

        .sidebar-step.active { color: var(--text); }
        .sidebar-step.done { color: var(--primary); }

        .step-dot {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            border: 2px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.75rem;
            font-weight: 600;
            flex-shrink: 0;
            transition: all 0.2s;
        }

        .sidebar-step.active .step-dot {
            border-color: var(--primary);
            color: var(--primary);
            background: rgba(6,182,212,0.1);
        }

        .sidebar-step.done .step-dot {
            border-color: var(--primary);
            background: var(--primary);
            color: #000;
        }

        .step-connector {
            width: 2px;
            height: 20px;
            background: var(--border);
            margin-left: 13px;
            transition: background 0.2s;
        }

        .step-connector.done { background: var(--primary); }

        .sidebar-footer {
            position: relative;
            z-index: 1;
            font-size: 0.75rem;
            color: var(--text-3);
        }

        /* ── Right Panel — Form ── */
        .setup-main {
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 48px;
        }

        .setup-form-wrap {
            width: 100%;
            max-width: 520px;
        }

        .step-content { display: none; }
        .step-content.active { display: block; }

        .form-title {
            font-size: 1.5rem;
            font-weight: 700;
            margin-bottom: 4px;
            letter-spacing: -0.02em;
        }

        .form-subtitle {
            color: var(--text-2);
            font-size: 0.875rem;
            margin-bottom: 32px;
        }

        /* ── Form Elements ── */
        .form-group { margin-bottom: 20px; }

        .form-group label {
            display: block;
            font-size: 0.8125rem;
            font-weight: 500;
            color: var(--text-2);
            margin-bottom: 6px;
        }

        .form-group input,
        .form-group select {
            width: 100%;
            padding: 10px 14px;
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            font-size: 0.875rem;
            font-family: var(--font);
            color: var(--text);
            background: var(--bg-input);
            transition: border-color 0.2s, box-shadow 0.2s;
            outline: none;
        }

        .form-group input:focus,
        .form-group select:focus {
            border-color: var(--border-focus);
            box-shadow: 0 0 0 2px rgba(6,182,212,0.1);
        }

        .form-group input::placeholder { color: var(--text-3); }

        .form-group .help-text {
            font-size: 0.75rem;
            color: var(--text-3);
            margin-top: 4px;
        }

        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 16px;
        }

        /* ── Buttons ── */
        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            padding: 10px 20px;
            border-radius: var(--radius-sm);
            font-size: 0.875rem;
            font-weight: 500;
            font-family: var(--font);
            cursor: pointer;
            border: 1px solid transparent;
            transition: all 0.15s;
            text-decoration: none;
            line-height: 1;
        }

        .btn:disabled { opacity: 0.5; cursor: not-allowed; }

        .btn-primary {
            background: var(--primary);
            color: #000;
            border-color: var(--primary);
            font-weight: 600;
        }

        .btn-primary:hover:not(:disabled) { background: var(--primary-hover); }

        .btn-secondary {
            background: transparent;
            color: var(--text);
            border-color: var(--border);
        }

        .btn-secondary:hover:not(:disabled) {
            background: rgba(255,255,255,0.05);
            border-color: rgba(255,255,255,0.15);
        }

        .form-footer {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 32px;
        }

        /* ── Alerts ── */
        .alert {
            padding: 12px 16px;
            border-radius: var(--radius-sm);
            font-size: 0.8125rem;
            margin-bottom: 20px;
            display: none;
        }

        .alert.show { display: flex; align-items: center; gap: 8px; }
        .alert-success { background: rgba(34,197,94,0.1); color: var(--success); border: 1px solid rgba(34,197,94,0.2); }
        .alert-error { background: rgba(239,68,68,0.1); color: var(--error); border: 1px solid rgba(239,68,68,0.2); }
        .alert-info { background: rgba(59,130,246,0.1); color: var(--info); border: 1px solid rgba(59,130,246,0.2); }

        /* ── Spinner ── */
        .spinner {
            width: 18px; height: 18px;
            border: 2px solid var(--border);
            border-top-color: var(--primary);
            border-radius: 50%;
            animation: spin 0.6s linear infinite;
            display: inline-block;
        }

        @keyframes spin { to { transform: rotate(360deg); } }

        /* ── Success ── */
        .success-content { text-align: center; padding: 32px 0; }

        .success-icon {
            width: 72px; height: 72px;
            background: rgba(6,182,212,0.1);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 24px;
        }

        .success-icon svg { width: 36px; height: 36px; color: var(--primary); }

        .success-content h2 { font-size: 1.5rem; margin-bottom: 8px; }
        .success-content p { color: var(--text-2); margin-bottom: 24px; }

        .success-actions { display: flex; gap: 12px; justify-content: center; }

        /* ── Step transitions ── */
        .step-content {
            display: none;
            opacity: 0;
            transform: translateX(16px);
        }

        .step-content.active {
            display: block;
            animation: stepIn 0.3s ease forwards;
        }

        @keyframes stepIn {
            from { opacity: 0; transform: translateX(16px); }
            to   { opacity: 1; transform: translateX(0); }
        }

        /* Button loading state */
        .btn.loading {
            position: relative;
            color: transparent !important;
            pointer-events: none;
        }

        .btn.loading::after {
            content: '';
            position: absolute;
            width: 18px;
            height: 18px;
            border: 2px solid rgba(255,255,255,0.3);
            border-top-color: #fff;
            border-radius: 50%;
            animation: spin 0.6s linear infinite;
        }

        .btn-secondary.loading::after {
            border-color: var(--border);
            border-top-color: var(--text);
        }

        /* Progress bar at top of form area */
        .setup-progress {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 2px;
            background: var(--border);
            z-index: 10;
            overflow: hidden;
        }

        .setup-progress-bar {
            height: 100%;
            background: var(--primary);
            transition: width 0.4s ease;
            width: 0%;
        }

        /* ── DB Fields ── */
        .db-network-fields { display: block; }
        .db-sqlite-fields { display: none; }

        /* ── Responsive ── */
        @media (max-width: 768px) {
            .setup-layout {
                grid-template-columns: 1fr;
            }

            .setup-sidebar {
                padding: 24px;
                border-right: none;
                border-bottom: 1px solid var(--border);
            }

            .sidebar-steps { flex-direction: row; gap: 12px; }
            .step-connector { display: none; }
            .sidebar-tagline { margin-bottom: 24px; }
            .sidebar-footer { display: none; }

            .setup-main { padding: 24px; }
            .form-row { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>

<div class="setup-layout">
    <!-- Left Panel — Info & Steps -->
    <aside class="setup-sidebar">
        <div class="sidebar-content">
            <div class="sidebar-logo">⚡ ZephyrPHP</div>
            <p class="sidebar-tagline">Setup your CMS in minutes</p>

            <ul class="sidebar-steps">
                <li class="sidebar-step active" data-sidebar="1">
                    <span class="step-dot">1</span>
                    Application
                </li>
                <div class="step-connector" data-conn="1"></div>
                <li class="sidebar-step" data-sidebar="2">
                    <span class="step-dot">2</span>
                    Database
                </li>
                <div class="step-connector" data-conn="2"></div>
                <li class="sidebar-step" data-sidebar="3">
                    <span class="step-dot">3</span>
                    Admin Account
                </li>
            </ul>
        </div>
        <div class="sidebar-footer">
            &copy; {{ "now"|date("Y") }} ZephyrPHP &middot; MIT License
        </div>
    </aside>

    <!-- Right Panel — Form -->
    <main class="setup-main">
        <div class="setup-progress"><div class="setup-progress-bar" id="progress-bar"></div></div>
        <div class="setup-form-wrap">

            {% if writable_errors is not empty %}
            <div class="alert alert-error show" style="margin-bottom:24px;">
                <div>
                    <strong>Permission Issues</strong><br>
                    {% for error in writable_errors %}
                        {{ error }}<br>
                    {% endfor %}
                </div>
            </div>
            {% endif %}

            <!-- Step 1: App Settings -->
            <div class="step-content active" data-step="1">
                <h2 class="form-title">Application</h2>
                <p class="form-subtitle">Name your site and set the environment</p>

                <div id="alert-step1" class="alert"></div>
                <div class="form-group">
                    <label for="app_name">Site Name</label>
                    <input type="text" id="app_name" value="{{ env.APP_NAME ?? 'ZephyrPHP' }}" placeholder="My Awesome Site">
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label for="environment">Environment</label>
                        <select id="environment">
                            <option value="dev" {{ (env.ENV ?? 'dev') == 'dev' ? 'selected' : '' }}>Development</option>
                            <option value="production" {{ (env.ENV ?? '') == 'production' ? 'selected' : '' }}>Production</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="timezone">Timezone</label>
                        <select id="timezone">
                            {% for tz in timezones %}
                            <option value="{{ tz }}" {{ (env.APP_TIMEZONE ?? 'UTC') == tz ? 'selected' : '' }}>{{ tz }}</option>
                            {% endfor %}
                        </select>
                    </div>
                </div>
                <div class="form-footer">
                    <div></div>
                    <button class="btn btn-primary" id="btn-step1-next">
                        Continue
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                    </button>
                </div>
            </div>

            <!-- Step 2: Database -->
            <div class="step-content" data-step="2">
                <h2 class="form-title">Database</h2>
                <p class="form-subtitle">Connect to your database — it will be tested and set up automatically</p>

                <div id="alert-step2" class="alert"></div>
                <div class="form-group">
                    <label for="db_driver">Driver</label>
                    <select id="db_driver">
                        <option value="pdo_mysql" {{ (env.DB_CONNECTION ?? 'pdo_mysql') == 'pdo_mysql' ? 'selected' : '' }}>MySQL / MariaDB</option>
                        <option value="pdo_pgsql" {{ (env.DB_CONNECTION ?? '') == 'pdo_pgsql' ? 'selected' : '' }}>PostgreSQL</option>
                        <option value="pdo_sqlite" {{ (env.DB_CONNECTION ?? '') == 'pdo_sqlite' ? 'selected' : '' }}>SQLite</option>
                        <option value="pdo_sqlsrv" {{ (env.DB_CONNECTION ?? '') == 'pdo_sqlsrv' ? 'selected' : '' }}>SQL Server</option>
                    </select>
                </div>
                <div class="db-network-fields">
                    <div class="form-row">
                        <div class="form-group">
                            <label for="db_host">Host</label>
                            <input type="text" id="db_host" value="{{ env.DB_HOST ?? '127.0.0.1' }}" placeholder="127.0.0.1">
                        </div>
                        <div class="form-group">
                            <label for="db_port">Port</label>
                            <input type="text" id="db_port" value="{{ env.DB_PORT ?? '3306' }}" placeholder="3306">
                        </div>
                    </div>
                    <div class="form-group">
                        <label for="db_name">Database Name</label>
                        <input type="text" id="db_name" value="{{ env.DB_DATABASE ?? 'zephyrphp' }}" placeholder="my_database">
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label for="db_user">Username</label>
                            <input type="text" id="db_user" value="{{ env.DB_USERNAME ?? 'root' }}" placeholder="root">
                        </div>
                        <div class="form-group">
                            <label for="db_pass">Password</label>
                            <input type="password" id="db_pass" value="{{ env.DB_PASSWORD ?? '' }}" placeholder="Password">
                        </div>
                    </div>
                </div>
                <div class="db-sqlite-fields">
                    <div class="form-group">
                        <label for="db_path">Database File Path</label>
                        <input type="text" id="db_path" value="database/database.sqlite" placeholder="database/database.sqlite">
                        <div class="help-text">Relative to project root</div>
                    </div>
                </div>
                <div class="form-footer">
                    <button class="btn btn-secondary" id="btn-step2-back">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
                        Back
                    </button>
                    <button class="btn btn-primary" id="btn-step2-next">
                        Continue
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                    </button>
                </div>
            </div>

            <!-- Step 3: Admin Account -->
            <div class="step-content" data-step="3">
                <h2 class="form-title">Admin Account</h2>
                <p class="form-subtitle">Create your administrator account</p>

                <div id="alert-step3" class="alert"></div>
                <div class="form-group">
                    <label for="admin_name">Full Name</label>
                    <input type="text" id="admin_name" placeholder="John Doe" required>
                </div>
                <div class="form-group">
                    <label for="admin_email">Email Address</label>
                    <input type="email" id="admin_email" placeholder="admin@example.com" required>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label for="admin_password">Password</label>
                        <input type="password" id="admin_password" placeholder="Min. 12 characters" required>
                    </div>
                    <div class="form-group">
                        <label for="admin_password_confirm">Confirm Password</label>
                        <input type="password" id="admin_password_confirm" placeholder="Repeat password" required>
                    </div>
                </div>
                <div class="form-footer">
                    <button class="btn btn-secondary" id="btn-step3-back">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
                        Back
                    </button>
                    <button class="btn btn-primary" id="btn-create-admin">
                        Create Account & Launch CMS
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                    </button>
                </div>
            </div>

        </div>
    </main>
</div>

<script nonce="{{ csp_nonce() }}">
    let currentStep = 1;
    const totalSteps = 3;

    function setProgress(step) {
        const pct = Math.round(((step - 1) / (totalSteps - 1)) * 100);
        document.getElementById('progress-bar').style.width = pct + '%';
    }

    function btnLoading(btn, loading) {
        if (loading) {
            btn._origHtml = btn.innerHTML;
            btn.classList.add('loading');
            btn.disabled = true;
        } else {
            btn.classList.remove('loading');
            btn.disabled = false;
            if (btn._origHtml) btn.innerHTML = btn._origHtml;
        }
    }

    function goToStep(step) {
        // Fade out current
        const current = document.querySelector('.step-content.active');
        if (current) {
            current.style.animation = 'none';
            current.classList.remove('active');
        }

        // Small delay for clean transition
        setTimeout(() => {
            document.querySelector(`.step-content[data-step="${step}"]`).classList.add('active');
        }, 50);

        // Update sidebar steps
        document.querySelectorAll('.sidebar-step').forEach(el => {
            const s = parseInt(el.dataset.sidebar);
            el.classList.remove('active', 'done');
            if (s < step) {
                el.classList.add('done');
                el.querySelector('.step-dot').innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>';
            } else if (s === step) {
                el.classList.add('active');
                el.querySelector('.step-dot').textContent = s;
            } else {
                el.querySelector('.step-dot').textContent = s;
            }
        });

        // Update connectors
        document.querySelectorAll('.step-connector').forEach(el => {
            const c = parseInt(el.dataset.conn);
            el.classList.toggle('done', c < step);
        });

        currentStep = step;
        setProgress(step);
    }

    // Set initial progress
    setProgress(1);

    function showAlert(stepId, type, message) {
        const alert = document.getElementById(`alert-step${stepId}`);
        alert.className = `alert alert-${type} show`;
        alert.textContent = message;
    }

    function hideAlert(stepId) {
        const alert = document.getElementById(`alert-step${stepId}`);
        if (alert) { alert.className = 'alert'; alert.textContent = ''; }
    }

    async function apiCall(url, data) {
        const response = await fetch(url, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'X-CSRF-TOKEN': '{{ csrf_token }}' },
            body: JSON.stringify(data)
        });
        return response.json();
    }

    // Step 1
    async function saveStep1() {
        hideAlert(1);
        const btn = document.getElementById('btn-step1-next');
        btnLoading(btn, true);
        try {
            const result = await apiCall('/setup/save-settings', {
                app_name: document.getElementById('app_name').value,
                environment: document.getElementById('environment').value,
                timezone: document.getElementById('timezone').value,
            });
            btnLoading(btn, false);
            if (result.success) { goToStep(2); }
            else { showAlert(1, 'error', result.error || 'Failed to save settings'); }
        } catch (e) {
            btnLoading(btn, false);
            showAlert(1, 'error', 'Network error.');
        }
    }

    // Step 2
    function toggleDbFields() {
        const driver = document.getElementById('db_driver').value;
        document.querySelector('.db-network-fields').style.display = driver === 'pdo_sqlite' ? 'none' : 'block';
        document.querySelector('.db-sqlite-fields').style.display = driver === 'pdo_sqlite' ? 'block' : 'none';
        if (driver !== 'pdo_sqlite') {
            const portMap = { pdo_mysql: '3306', pdo_pgsql: '5432', pdo_sqlsrv: '1433' };
            document.getElementById('db_port').value = portMap[driver] || '3306';
        }
    }

    function getDbData() {
        const driver = document.getElementById('db_driver').value;
        if (driver === 'pdo_sqlite') {
            return { db_driver: driver, db_path: document.getElementById('db_path').value };
        }
        return {
            db_driver: driver,
            db_host: document.getElementById('db_host').value,
            db_port: document.getElementById('db_port').value,
            db_name: document.getElementById('db_name').value,
            db_user: document.getElementById('db_user').value,
            db_pass: document.getElementById('db_pass').value,
        };
    }

    async function saveStep2() {
        hideAlert(2);
        const btn = document.getElementById('btn-step2-next');
        btnLoading(btn, true);

        try {
            const result = await apiCall('/setup/setup-database', getDbData());

            if (result.success) {
                // Show table creation progress
                const tableCount = result.tables ? result.tables.length : 0;
                showAlert(2, 'success', `Database configured — ${tableCount} tables created`);
                setTimeout(() => {
                    btnLoading(btn, false);
                    goToStep(3);
                }, 800);
            } else if (result.has_tables) {
                btnLoading(btn, false);
                showAlert(2, 'error', result.error);
                // Change button to confirm destructive action
                btn.innerHTML = 'Yes, Drop All &amp; Recreate <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>';
                btn.onclick = async function() {
                    hideAlert(2);
                    btnLoading(btn, true);
                    try {
                        const dbData = getDbData();
                        dbData.confirm_existing = true;
                        const r = await apiCall('/setup/setup-database', dbData);
                        btn.onclick = saveStep2;
                        if (r.success) {
                            const tableCount = r.tables ? r.tables.length : 0;
                            showAlert(2, 'success', `Database configured — ${tableCount} tables created`);
                            setTimeout(() => {
                                btnLoading(btn, false);
                                goToStep(3);
                            }, 800);
                        } else {
                            btnLoading(btn, false);
                            showAlert(2, 'error', r.error);
                        }
                    } catch (e) {
                        btnLoading(btn, false);
                        btn.onclick = saveStep2;
                        showAlert(2, 'error', 'Network error.');
                    }
                };
            } else {
                btnLoading(btn, false);
                showAlert(2, 'error', result.error);
            }
        } catch (e) {
            btnLoading(btn, false);
            showAlert(2, 'error', 'Network error. Please try again.');
        }
    }

    // Step 3
    async function createAdmin() {
        hideAlert(3);
        const password = document.getElementById('admin_password').value;
        const confirm = document.getElementById('admin_password_confirm').value;

        if (password !== confirm) { showAlert(3, 'error', 'Passwords do not match.'); return; }
        if (password.length < 12) { showAlert(3, 'error', 'Password must be at least 12 characters.'); return; }

        const btn = document.getElementById('btn-create-admin');
        btnLoading(btn, true);
        btn.innerHTML = '<span class="spinner"></span> Setting up...';

        try {
            const result = await apiCall('/setup/create-admin', {
                name: document.getElementById('admin_name').value,
                email: document.getElementById('admin_email').value,
                password: password,
                password_confirmation: confirm,
            });

            if (result.success && result.redirect) {
                // Success — redirect to admin dashboard (already logged in)
                showAlert(3, 'success', 'Account created! Redirecting to dashboard...');
                setTimeout(() => {
                    window.location.href = result.redirect;
                }, 1000);
            } else if (result.success) {
                btnLoading(btn, false);
                window.location.href = '/admin';
            } else {
                btnLoading(btn, false);
                showAlert(3, 'error', result.error);
            }
        } catch (e) {
            btnLoading(btn, false);
            showAlert(3, 'error', 'Network error.');
        }
    }

    // Bind events
    document.getElementById('btn-step1-next').addEventListener('click', saveStep1);
    document.getElementById('db_driver').addEventListener('change', toggleDbFields);
    document.getElementById('btn-step2-back').addEventListener('click', function() { goToStep(1); });
    document.getElementById('btn-step2-next').addEventListener('click', saveStep2);
    document.getElementById('btn-step3-back').addEventListener('click', function() { goToStep(2); });
    document.getElementById('btn-create-admin').addEventListener('click', createAdmin);
    toggleDbFields();
</script>

</body>
</html>
