<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Setup — ZephyrPHP</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style nonce="{{ csp_nonce() }}">
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --bg-app: #F1F1F1;
            --bg-surface: #FFFFFF;
            --bg-surface-hover: #F7F7F7;
            --text-primary: #303030;
            --text-secondary: #616161;
            --text-disabled: #B5B5B5;
            --border: #E3E3E3;
            --border-hover: #CCCCCC;
            --color-primary: #008060;
            --color-primary-hover: #006e52;
            --color-success: #047B5D;
            --color-critical: #D72C0D;
            --color-warning: #FFB800;
            --color-info: #2C6ECB;
            --shadow-card: 0 1px 0 rgba(26,26,26,0.07), 0 1px 3px rgba(26,26,26,0.1);
            --shadow-lg: 0 4px 16px rgba(26,26,26,0.12);
            --radius: 12px;
            --radius-sm: 8px;
            --font: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        }

        body {
            font-family: var(--font);
            background: var(--bg-app);
            color: var(--text-primary);
            line-height: 1.5;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 24px;
        }

        .setup-container {
            width: 100%;
            max-width: 640px;
        }

        .setup-logo {
            text-align: center;
            margin-bottom: 32px;
        }

        .setup-logo h1 {
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--text-primary);
        }

        .setup-logo p {
            color: var(--text-secondary);
            font-size: 0.875rem;
            margin-top: 4px;
        }

        /* Progress Bar */
        .progress-bar {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0;
            margin-bottom: 32px;
        }

        .progress-step {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .step-circle {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.8rem;
            font-weight: 600;
            border: 2px solid var(--border);
            color: var(--text-disabled);
            background: var(--bg-surface);
            transition: all 0.3s ease;
            flex-shrink: 0;
        }

        .step-circle.active {
            border-color: var(--color-primary);
            color: var(--color-primary);
            background: #e6f4ef;
        }

        .step-circle.done {
            border-color: var(--color-primary);
            background: var(--color-primary);
            color: white;
        }

        .step-label {
            font-size: 0.75rem;
            color: var(--text-disabled);
            font-weight: 500;
            display: none;
        }

        .step-line {
            width: 40px;
            height: 2px;
            background: var(--border);
            margin: 0 4px;
            transition: background 0.3s ease;
        }

        .step-line.done {
            background: var(--color-primary);
        }

        /* Card */
        .setup-card {
            background: var(--bg-surface);
            border-radius: var(--radius);
            box-shadow: var(--shadow-lg);
            overflow: hidden;
        }

        .card-header {
            padding: 24px 32px 0;
        }

        .card-header h2 {
            font-size: 1.25rem;
            font-weight: 600;
            margin-bottom: 4px;
        }

        .card-header p {
            color: var(--text-secondary);
            font-size: 0.875rem;
        }

        .card-body {
            padding: 24px 32px;
        }

        .card-footer {
            padding: 16px 32px 24px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 12px;
        }

        /* Form Elements */
        .form-group {
            margin-bottom: 20px;
        }

        .form-group label {
            display: block;
            font-size: 0.8125rem;
            font-weight: 500;
            color: var(--text-primary);
            margin-bottom: 6px;
        }

        .form-group input,
        .form-group select {
            width: 100%;
            padding: 10px 12px;
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            font-size: 0.875rem;
            font-family: var(--font);
            color: var(--text-primary);
            background: var(--bg-surface);
            transition: border-color 0.2s, box-shadow 0.2s;
            outline: none;
        }

        .form-group input:focus,
        .form-group select:focus {
            border-color: var(--color-info);
            box-shadow: 0 0 0 2px rgba(44, 110, 203, 0.15);
        }

        .form-group .help-text {
            font-size: 0.75rem;
            color: var(--text-secondary);
            margin-top: 4px;
        }

        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 16px;
        }

        /* Buttons */
        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            padding: 10px 20px;
            border-radius: var(--radius-sm);
            font-size: 0.875rem;
            font-weight: 500;
            font-family: var(--font);
            cursor: pointer;
            border: 1px solid transparent;
            transition: all 0.15s ease;
            text-decoration: none;
            line-height: 1;
        }

        .btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

        .btn-primary {
            background: var(--color-primary);
            color: white;
            border-color: var(--color-primary);
        }

        .btn-primary:hover:not(:disabled) {
            background: var(--color-primary-hover);
        }

        .btn-secondary {
            background: var(--bg-surface);
            color: var(--text-primary);
            border-color: var(--border);
        }

        .btn-secondary:hover:not(:disabled) {
            background: var(--bg-surface-hover);
            border-color: var(--border-hover);
        }

        .btn-outline {
            background: transparent;
            color: var(--color-primary);
            border-color: var(--border);
        }

        .btn-outline:hover:not(:disabled) {
            background: #e6f4ef;
        }

        .btn-sm {
            padding: 6px 12px;
            font-size: 0.8125rem;
        }

        /* Alerts */
        .alert {
            padding: 12px 16px;
            border-radius: var(--radius-sm);
            font-size: 0.8125rem;
            margin-bottom: 16px;
            display: none;
        }

        .alert.show { display: flex; align-items: center; gap: 8px; }

        .alert-success {
            background: #e6f4ef;
            color: var(--color-success);
            border: 1px solid rgba(4, 123, 93, 0.2);
        }

        .alert-error {
            background: #fef2f0;
            color: var(--color-critical);
            border: 1px solid rgba(215, 44, 13, 0.2);
        }

        .alert-info {
            background: #eef4fb;
            color: var(--color-info);
            border: 1px solid rgba(44, 110, 203, 0.2);
        }

        /* Install Checklist */
        .install-list {
            list-style: none;
        }

        .install-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 0;
            border-bottom: 1px solid var(--border);
            font-size: 0.875rem;
        }

        .install-item:last-child { border-bottom: none; }

        .install-icon {
            width: 24px;
            height: 24px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            background: var(--bg-surface-hover);
            color: var(--text-disabled);
            font-size: 0.75rem;
        }

        .install-item.done .install-icon {
            background: var(--color-primary);
            color: white;
        }

        .install-item.error .install-icon {
            background: var(--color-critical);
            color: white;
        }

        .install-item .item-label {
            flex: 1;
        }

        .install-item .item-status {
            font-size: 0.75rem;
            color: var(--text-disabled);
        }

        .install-item.done .item-status { color: var(--color-success); }
        .install-item.error .item-status { color: var(--color-critical); }

        /* Spinner */
        .spinner {
            width: 18px;
            height: 18px;
            border: 2px solid var(--border);
            border-top-color: var(--color-primary);
            border-radius: 50%;
            animation: spin 0.6s linear infinite;
            display: inline-block;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        /* Step Visibility */
        .step-content { display: none; }
        .step-content.active { display: block; }

        /* Success Page */
        .success-content {
            text-align: center;
            padding: 32px 0;
        }

        .success-icon {
            width: 80px;
            height: 80px;
            background: #e6f4ef;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 24px;
        }

        .success-icon svg {
            width: 40px;
            height: 40px;
            color: var(--color-primary);
        }

        .success-content h2 {
            font-size: 1.5rem;
            margin-bottom: 8px;
        }

        .success-content p {
            color: var(--text-secondary);
            margin-bottom: 24px;
        }

        .success-actions {
            display: flex;
            gap: 12px;
            justify-content: center;
        }

        /* DB Fields visibility */
        .db-network-fields { display: block; }
        .db-sqlite-fields { display: none; }

        /* Responsive */
        @media (max-width: 640px) {
            body { padding: 16px; }
            .card-header, .card-body, .card-footer { padding-left: 20px; padding-right: 20px; }
            .form-row { grid-template-columns: 1fr; }
            .step-line { width: 24px; }
        }
    </style>
</head>
<body>

<div class="setup-container">
    <div class="setup-logo">
        <h1>ZephyrPHP</h1>
        <p>Let's get your application set up</p>
    </div>

    <!-- Progress Bar -->
    <div class="progress-bar">
        <div class="progress-step">
            <div class="step-circle active" data-step="1">1</div>
        </div>
        <div class="step-line" data-line="1"></div>
        <div class="progress-step">
            <div class="step-circle" data-step="2">2</div>
        </div>
        <div class="step-line" data-line="2"></div>
        <div class="progress-step">
            <div class="step-circle" data-step="3">3</div>
        </div>
        <div class="step-line" data-line="3"></div>
        <div class="progress-step">
            <div class="step-circle" data-step="4">4</div>
        </div>
        <div class="step-line" data-line="4"></div>
        <div class="progress-step">
            <div class="step-circle" data-step="5">5</div>
        </div>
    </div>

    <div class="setup-card">
        <!-- Step 1: App Settings -->
        <div class="step-content active" data-step="1">
            <div class="card-header">
                <h2>Application Settings</h2>
                <p>Configure your application's basic settings</p>
            </div>
            <div class="card-body">
                <div id="alert-step1" class="alert"></div>
                <div class="form-group">
                    <label for="app_name">Application Name</label>
                    <input type="text" id="app_name" value="{{ env.APP_NAME ?? 'ZephyrPHP' }}" placeholder="My Awesome Site">
                </div>
                <div class="form-group">
                    <label for="app_url">Application URL</label>
                    <input type="text" id="app_url" value="{{ env.APP_URL ?? 'http://localhost:8000' }}" placeholder="http://localhost:8000">
                    <div class="help-text">The URL where your app will be accessible</div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label for="environment">Environment</label>
                        <select id="environment">
                            <option value="dev" {{ (env.ENV ?? 'dev') == 'dev' ? 'selected' : '' }}>Development</option>
                            <option value="production" {{ (env.ENV ?? '') == 'production' ? 'selected' : '' }}>Production</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="timezone">Timezone</label>
                        <select id="timezone">
                            {% for tz in timezones %}
                            <option value="{{ tz }}" {{ (env.APP_TIMEZONE ?? 'UTC') == tz ? 'selected' : '' }}>{{ tz }}</option>
                            {% endfor %}
                        </select>
                    </div>
                </div>
            </div>
            <div class="card-footer">
                <div></div>
                <button class="btn btn-primary" onclick="saveStep1()">
                    Continue
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </button>
            </div>
        </div>

        <!-- Step 2: Database -->
        <div class="step-content" data-step="2">
            <div class="card-header">
                <h2>Database Configuration</h2>
                <p>Connect your application to a database</p>
            </div>
            <div class="card-body">
                <div id="alert-step2" class="alert"></div>
                <div class="form-group">
                    <label for="db_driver">Database Driver</label>
                    <select id="db_driver" onchange="toggleDbFields()">
                        <option value="pdo_mysql" {{ (env.DB_CONNECTION ?? 'pdo_mysql') == 'pdo_mysql' ? 'selected' : '' }}>MySQL / MariaDB</option>
                        <option value="pdo_pgsql" {{ (env.DB_CONNECTION ?? '') == 'pdo_pgsql' ? 'selected' : '' }}>PostgreSQL</option>
                        <option value="pdo_sqlite" {{ (env.DB_CONNECTION ?? '') == 'pdo_sqlite' ? 'selected' : '' }}>SQLite</option>
                        <option value="pdo_sqlsrv" {{ (env.DB_CONNECTION ?? '') == 'pdo_sqlsrv' ? 'selected' : '' }}>SQL Server</option>
                    </select>
                </div>
                <div class="db-network-fields">
                    <div class="form-row">
                        <div class="form-group">
                            <label for="db_host">Host</label>
                            <input type="text" id="db_host" value="{{ env.DB_HOST ?? '127.0.0.1' }}" placeholder="127.0.0.1">
                        </div>
                        <div class="form-group">
                            <label for="db_port">Port</label>
                            <input type="text" id="db_port" value="{{ env.DB_PORT ?? '3306' }}" placeholder="3306">
                        </div>
                    </div>
                    <div class="form-group">
                        <label for="db_name">Database Name</label>
                        <input type="text" id="db_name" value="{{ env.DB_DATABASE ?? 'zephyrphp' }}" placeholder="my_database">
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label for="db_user">Username</label>
                            <input type="text" id="db_user" value="{{ env.DB_USERNAME ?? 'root' }}" placeholder="root">
                        </div>
                        <div class="form-group">
                            <label for="db_pass">Password</label>
                            <input type="password" id="db_pass" value="{{ env.DB_PASSWORD ?? '' }}" placeholder="Password">
                        </div>
                    </div>
                </div>
                <div class="db-sqlite-fields">
                    <div class="form-group">
                        <label for="db_path">Database File Path</label>
                        <input type="text" id="db_path" value="database/database.sqlite" placeholder="database/database.sqlite">
                        <div class="help-text">Relative to project root</div>
                    </div>
                </div>
                <div style="display: flex; gap: 8px;">
                    <button class="btn btn-outline btn-sm" onclick="testDb()">
                        <span class="test-db-text">Test Connection</span>
                        <span class="test-db-spinner spinner" style="display:none;"></span>
                    </button>
                    <button class="btn btn-outline btn-sm" id="btn-create-db" onclick="createDb()" style="display:none;">
                        Create Database
                    </button>
                </div>
            </div>
            <div class="card-footer">
                <button class="btn btn-secondary" onclick="goToStep(1)">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
                    Back
                </button>
                <button class="btn btn-primary" id="btn-step2-next" onclick="saveStep2()">
                    Continue
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </button>
            </div>
        </div>

        <!-- Step 3: Install Tables -->
        <div class="step-content" data-step="3">
            <div class="card-header">
                <h2>Install Database</h2>
                <p>Create the required database tables</p>
            </div>
            <div class="card-body">
                <div id="alert-step3" class="alert"></div>
                <ul class="install-list">
                    <li class="install-item" data-table="users">
                        <div class="install-icon">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                        </div>
                        <span class="item-label">Users & Authentication</span>
                        <span class="item-status">Pending</span>
                    </li>
                    <li class="install-item" data-table="roles">
                        <div class="install-icon">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                        </div>
                        <span class="item-label">Roles & Permissions</span>
                        <span class="item-status">Pending</span>
                    </li>
                    <li class="install-item" data-table="cms_page_types">
                        <div class="install-icon">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                        </div>
                        <span class="item-label">CMS Pages & Collections</span>
                        <span class="item-status">Pending</span>
                    </li>
                    <li class="install-item" data-table="cms_themes">
                        <div class="install-icon">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 19l7-7 3 3-7 7-3-3z"/><path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"/><path d="M2 2l7.586 7.586"/><circle cx="11" cy="11" r="2"/></svg>
                        </div>
                        <span class="item-label">Themes & Design</span>
                        <span class="item-status">Pending</span>
                    </li>
                    <li class="install-item" data-table="cms_media">
                        <div class="install-icon">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                        </div>
                        <span class="item-label">Media Library</span>
                        <span class="item-status">Pending</span>
                    </li>
                </ul>
            </div>
            <div class="card-footer">
                <button class="btn btn-secondary" onclick="goToStep(2)">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
                    Back
                </button>
                <button class="btn btn-primary" id="btn-install" onclick="installTables()">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                    Install
                </button>
            </div>
        </div>

        <!-- Step 4: Admin Account -->
        <div class="step-content" data-step="4">
            <div class="card-header">
                <h2>Create Admin Account</h2>
                <p>Set up your administrator account</p>
            </div>
            <div class="card-body">
                <div id="alert-step4" class="alert"></div>
                <div class="form-group">
                    <label for="admin_name">Full Name</label>
                    <input type="text" id="admin_name" placeholder="John Doe" required>
                </div>
                <div class="form-group">
                    <label for="admin_email">Email Address</label>
                    <input type="email" id="admin_email" placeholder="admin@example.com" required>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label for="admin_password">Password</label>
                        <input type="password" id="admin_password" placeholder="Min. 8 characters" required>
                    </div>
                    <div class="form-group">
                        <label for="admin_password_confirm">Confirm Password</label>
                        <input type="password" id="admin_password_confirm" placeholder="Repeat password" required>
                    </div>
                </div>
            </div>
            <div class="card-footer">
                <button class="btn btn-secondary" onclick="goToStep(3)">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
                    Back
                </button>
                <button class="btn btn-primary" onclick="createAdmin()">
                    Create Account
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </button>
            </div>
        </div>

        <!-- Step 5: Complete -->
        <div class="step-content" data-step="5">
            <div class="card-body">
                <div class="success-content">
                    <div class="success-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                    </div>
                    <h2>You're all set!</h2>
                    <p>Your ZephyrPHP application has been configured successfully.</p>
                    <div class="success-actions">
                        <a href="/" class="btn btn-secondary">Visit Your Site</a>
                        <a href="/cms" class="btn btn-primary">Go to CMS Dashboard</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script nonce="{{ csp_nonce() }}">
    let currentStep = 1;
    let dbTested = false;

    function goToStep(step) {
        // Hide all steps
        document.querySelectorAll('.step-content').forEach(el => el.classList.remove('active'));
        // Show target step
        document.querySelector(`.step-content[data-step="${step}"]`).classList.add('active');

        // Update progress circles
        document.querySelectorAll('.step-circle').forEach(circle => {
            const s = parseInt(circle.dataset.step);
            circle.classList.remove('active', 'done');
            if (s < step) {
                circle.classList.add('done');
                circle.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>';
            } else if (s === step) {
                circle.classList.add('active');
                circle.textContent = s;
            } else {
                circle.textContent = s;
            }
        });

        // Update progress lines
        document.querySelectorAll('.step-line').forEach(line => {
            const l = parseInt(line.dataset.line);
            line.classList.toggle('done', l < step);
        });

        currentStep = step;
    }

    function showAlert(stepId, type, message) {
        const alert = document.getElementById(`alert-step${stepId}`);
        alert.className = `alert alert-${type} show`;
        alert.innerHTML = message;
    }

    function hideAlert(stepId) {
        const alert = document.getElementById(`alert-step${stepId}`);
        if (alert) {
            alert.className = 'alert';
            alert.innerHTML = '';
        }
    }

    async function apiCall(url, data) {
        const response = await fetch(url, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
        });
        return response.json();
    }

    // Step 1: Save App Settings
    async function saveStep1() {
        hideAlert(1);
        try {
            const result = await apiCall('/setup/save-settings', {
                app_name: document.getElementById('app_name').value,
                app_url: document.getElementById('app_url').value,
                environment: document.getElementById('environment').value,
                timezone: document.getElementById('timezone').value,
            });
            if (result.success) {
                goToStep(2);
            } else {
                showAlert(1, 'error', result.error || 'Failed to save settings');
            }
        } catch (e) {
            showAlert(1, 'error', 'Network error. Please try again.');
        }
    }

    // Step 2: Database
    function toggleDbFields() {
        const driver = document.getElementById('db_driver').value;
        const networkFields = document.querySelector('.db-network-fields');
        const sqliteFields = document.querySelector('.db-sqlite-fields');

        if (driver === 'pdo_sqlite') {
            networkFields.style.display = 'none';
            sqliteFields.style.display = 'block';
        } else {
            networkFields.style.display = 'block';
            sqliteFields.style.display = 'none';
            // Update default port
            const portMap = { pdo_mysql: '3306', pdo_pgsql: '5432', pdo_sqlsrv: '1433' };
            document.getElementById('db_port').value = portMap[driver] || '3306';
        }
        dbTested = false;
    }

    function getDbData() {
        const driver = document.getElementById('db_driver').value;
        if (driver === 'pdo_sqlite') {
            return { db_driver: driver, db_path: document.getElementById('db_path').value };
        }
        return {
            db_driver: driver,
            db_host: document.getElementById('db_host').value,
            db_port: document.getElementById('db_port').value,
            db_name: document.getElementById('db_name').value,
            db_user: document.getElementById('db_user').value,
            db_pass: document.getElementById('db_pass').value,
        };
    }

    async function testDb() {
        hideAlert(2);
        document.querySelector('.test-db-text').style.display = 'none';
        document.querySelector('.test-db-spinner').style.display = 'inline-block';

        try {
            const result = await apiCall('/setup/test-db', getDbData());
            document.querySelector('.test-db-text').style.display = 'inline';
            document.querySelector('.test-db-spinner').style.display = 'none';

            if (result.success) {
                if (result.db_exists === false) {
                    showAlert(2, 'info', 'Connected! Database does not exist yet.');
                    document.getElementById('btn-create-db').style.display = 'inline-flex';
                } else {
                    showAlert(2, 'success', 'Connection successful!');
                    document.getElementById('btn-create-db').style.display = 'none';
                }
                dbTested = true;
            } else {
                showAlert(2, 'error', result.error);
                dbTested = false;
            }
        } catch (e) {
            document.querySelector('.test-db-text').style.display = 'inline';
            document.querySelector('.test-db-spinner').style.display = 'none';
            showAlert(2, 'error', 'Network error. Please try again.');
        }
    }

    async function createDb() {
        hideAlert(2);
        try {
            const result = await apiCall('/setup/create-db', getDbData());
            if (result.success) {
                showAlert(2, 'success', result.message);
                document.getElementById('btn-create-db').style.display = 'none';
                dbTested = true;
            } else {
                showAlert(2, 'error', result.error);
            }
        } catch (e) {
            showAlert(2, 'error', 'Network error.');
        }
    }

    async function saveStep2() {
        hideAlert(2);
        if (!dbTested) {
            showAlert(2, 'info', 'Please test your database connection first.');
            return;
        }

        try {
            const result = await apiCall('/setup/save-database', getDbData());
            if (result.success) {
                goToStep(3);
            } else {
                showAlert(2, 'error', result.error);
            }
        } catch (e) {
            showAlert(2, 'error', 'Network error.');
        }
    }

    // Step 3: Install Tables
    async function installTables() {
        hideAlert(3);
        const btn = document.getElementById('btn-install');
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner"></span> Installing...';

        // Set all items to pending with spinner
        document.querySelectorAll('.install-item').forEach(item => {
            item.querySelector('.item-status').textContent = 'Waiting...';
        });

        try {
            const result = await apiCall('/setup/install-tables', {});

            if (result.success) {
                // Animate checklist completion
                const items = document.querySelectorAll('.install-item');
                for (let i = 0; i < items.length; i++) {
                    await new Promise(r => setTimeout(r, 300));
                    items[i].classList.add('done');
                    items[i].querySelector('.install-icon').innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>';
                    items[i].querySelector('.item-status').textContent = 'Installed';
                }

                await new Promise(r => setTimeout(r, 500));
                btn.innerHTML = 'Continue <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>';
                btn.disabled = false;
                btn.onclick = () => goToStep(4);
            } else {
                showAlert(3, 'error', result.error);
                btn.innerHTML = 'Retry';
                btn.disabled = false;
                btn.onclick = installTables;
            }
        } catch (e) {
            showAlert(3, 'error', 'Installation failed. Check your database connection.');
            btn.innerHTML = 'Retry';
            btn.disabled = false;
            btn.onclick = installTables;
        }
    }

    // Step 4: Create Admin
    async function createAdmin() {
        hideAlert(4);

        const password = document.getElementById('admin_password').value;
        const confirm = document.getElementById('admin_password_confirm').value;

        if (password !== confirm) {
            showAlert(4, 'error', 'Passwords do not match.');
            return;
        }

        if (password.length < 8) {
            showAlert(4, 'error', 'Password must be at least 8 characters.');
            return;
        }

        try {
            const result = await apiCall('/setup/create-admin', {
                name: document.getElementById('admin_name').value,
                email: document.getElementById('admin_email').value,
                password: password,
                password_confirmation: confirm,
            });

            if (result.success) {
                // Complete installation
                const completeResult = await apiCall('/setup/complete', {});
                if (completeResult.success) {
                    goToStep(5);
                } else {
                    showAlert(4, 'error', completeResult.error || 'Failed to finalize setup.');
                }
            } else {
                showAlert(4, 'error', result.error);
            }
        } catch (e) {
            showAlert(4, 'error', 'Network error. Please try again.');
        }
    }

    // Initialize DB fields visibility
    toggleDbFields();
</script>

</body>
</html>
