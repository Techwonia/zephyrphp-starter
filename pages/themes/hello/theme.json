{
    "name": "Hello",
    "version": "1.0.0",
    "description": "A clean, minimal starter theme for ZephyrPHP CMS",
    "layouts": {
        "base": {
            "name": "Standard",
            "description": "Standard page layout with header and footer"
        }
    },
    "assets": {
        "css": [
            "css/theme.css"
        ],
        "js": [],
        "preload": [],
        "preconnect": [],
        "external_css": [],
        "external_js": [],
        "csp": {
            "default-src": "'self'",
            "script-src": "'self'",
            "style-src": "'self' 'unsafe-inline'",
            "img-src": "'self' data:",
            "font-src": "'self'"
        }
    }
}
