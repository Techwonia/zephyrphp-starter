{
    "name": "Hello",
    "version": "1.0.0",
    "description": "A clean, minimal starter theme for ZephyrPHP CMS",
    "layouts": {
        "base": {
            "name": "Standard",
            "description": "Standard page layout with header and footer"
        }
    },
    "assets": {
        "css": [
            "css/theme.css"
        ],
        "js": [],
        "preload": [],
        "preconnect": [],
        "external_css": [],
        "external_js": [],
        "csp": {
            "default-src": "'self'",
            "script-src": "'self'",
            "style-src": "'self' 'unsafe-inline'",
            "img-src": "'self' data:",
            "font-src": "'self'"
        }
    },
    "settings_schema": [
        {
            "name": "Colors",
            "settings": [
                {"type": "color", "id": "primary_color", "label": "Primary Color", "default": "#111111"},
                {"type": "color", "id": "bg_color", "label": "Background", "default": "#ffffff"},
                {"type": "color", "id": "text_color", "label": "Text Color", "default": "#111111"},
                {"type": "color", "id": "text_secondary_color", "label": "Muted Text", "default": "#666666"}
            ]
        }
    ]
}
