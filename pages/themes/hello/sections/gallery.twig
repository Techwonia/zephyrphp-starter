<section class="section-gallery" style="background:{{ section.settings.bg_color|default('#ffffff') }}; padding:{{ section.settings.padding|default(60) }}px 0;">
    <div class="container">
        {% if section.settings.heading %}
            <h2 style="text-align:{{ section.settings.text_align|default('center') }}; color:{{ section.settings.heading_color|default('#303030') }}; margin-bottom:32px;">
                {{ section.settings.heading }}
            </h2>
        {% endif %}

        {% if section.blocks|length > 0 %}
            <div style="display:grid; grid-template-columns:repeat({{ section.settings.columns|default(3) }}, 1fr); gap:{{ section.settings.gap|default(8) }}px;">
                {% for block in section.blocks %}
                    {% if block.type == 'image' %}
                        <div style="overflow:hidden; border-radius:{{ section.settings.border_radius|default(4) }}px; aspect-ratio:{{ section.settings.aspect_ratio|default('1/1') }};">
                            {% if block.settings.image %}
                                <img src="/{{ block.settings.image }}" alt="{{ block.settings.alt|default('') }}" style="width:100%; height:100%; object-fit:cover; transition:transform 0.3s;">
                            {% else %}
                                <div style="width:100%; height:100%; background:#f0f0f0; display:flex; align-items:center; justify-content:center; color:#999;">No Image</div>
                            {% endif %}
                        </div>
                    {% endif %}
                {% endfor %}
            </div>
        {% else %}
            <p style="text-align:center; color:#999;">Add image blocks to populate the gallery.</p>
        {% endif %}
    </div>
</section>

{% schema %}
{
    "name": "Gallery",
    "description": "Image gallery in a grid layout",
    "icon": "gallery",
    "settings": [
        {"type": "text", "id": "heading", "label": "Heading"},
        {"type": "select", "id": "columns", "label": "Columns", "default": "3",
         "options": [{"value": "2", "label": "2 Columns"}, {"value": "3", "label": "3 Columns"}, {"value": "4", "label": "4 Columns"}, {"value": "5", "label": "5 Columns"}]},
        {"type": "select", "id": "aspect_ratio", "label": "Aspect Ratio", "default": "1/1",
         "options": [{"value": "1/1", "label": "Square"}, {"value": "4/3", "label": "Landscape (4:3)"}, {"value": "3/4", "label": "Portrait (3:4)"}, {"value": "16/9", "label": "Widescreen (16:9)"}]},
        {"type": "range", "id": "gap", "label": "Gap (px)", "min": 0, "max": 24, "step": 2, "default": 8},
        {"type": "range", "id": "border_radius", "label": "Border Radius (px)", "min": 0, "max": 20, "step": 2, "default": 4},
        {"type": "select", "id": "text_align", "label": "Header Alignment", "default": "center",
         "options": [{"value": "left", "label": "Left"}, {"value": "center", "label": "Center"}]},
        {"type": "color", "id": "bg_color", "label": "Background Color", "default": "#ffffff"},
        {"type": "color", "id": "heading_color", "label": "Heading Color", "default": "#303030"},
        {"type": "range", "id": "padding", "label": "Section Padding (px)", "min": 0, "max": 120, "step": 4, "default": 60}
    ],
    "blocks": [
        {
            "type": "image",
            "name": "Image",
            "settings": [
                {"type": "image", "id": "image", "label": "Image"},
                {"type": "text", "id": "alt", "label": "Alt Text"}
            ]
        }
    ],
    "presets": [
        {"name": "Gallery", "settings": {"heading": "Gallery", "columns": "3"}}
    ]
}
{% endschema %}
