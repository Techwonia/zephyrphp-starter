<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    {{ assets_csp()|raw }}
    <title>{% block title %}{{ seo.title ?? page.title ?? config('app.name', 'ZephyrPHP') }}{% endblock %}</title>
    {% if seo is defined and seo.description is defined and seo.description %}
    <meta name="description" content="{{ seo.description }}">
    {% endif %}
    {% block meta %}{% endblock %}
    {{ assets_head()|raw }}
    {% if theme_settings is defined and theme_settings %}
    <style nonce="{{ csp_style_nonce() }}">
        :root {
            --color-primary: {{ theme_settings.primary_color|default('#111111')|e('css') }};
            --color-bg: {{ theme_settings.bg_color|default('#ffffff')|e('css') }};
            --color-text: {{ theme_settings.text_color|default('#111111')|e('css') }};
            --color-muted: {{ theme_settings.text_secondary_color|default('#666666')|e('css') }};
        }
    </style>
    {% endif %}
    {% block styles %}{% endblock %}
</head>
<body>
    {% if is_theme_preview is defined and is_theme_preview %}
    <div class="preview-banner">Preview: {{ preview_theme_slug }} &mdash; <a href="{{ admin_url('themes') }}">Back</a></div>
    {% endif %}

    {% include "@theme/partials/header.twig" %}

    {% if flash('success') %}
        <div class="container"><div class="alert alert--success">{{ flash('success') }}</div></div>
    {% endif %}
    {% if flash('error') %}
        <div class="container"><div class="alert alert--error">{{ flash('error') }}</div></div>
    {% endif %}

    <main>
        {% block body %}
        {% if use_sections is defined and use_sections and sections_html is defined %}
            {{ sections_html|raw }}
        {% else %}
        <div class="container">
            {% block content %}{% endblock %}
        </div>
        {% endif %}
        {% endblock %}
    </main>

    {% include "@theme/partials/footer.twig" %}
    {{ assets_footer()|raw }}
    {% block scripts %}{% endblock %}
</body>
</html>
