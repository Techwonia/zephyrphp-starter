<section class="section-features" style="background:{{ section.settings.bg_color|default('#ffffff') }}; padding:{{ section.settings.padding|default(60) }}px 0;">
    <div class="container">
        {% if section.settings.heading %}
            <h2 style="text-align:{{ section.settings.text_align|default('center') }}; color:{{ section.settings.heading_color|default('#303030') }}; margin-bottom:12px;">
                {{ section.settings.heading }}
            </h2>
        {% endif %}
        {% if section.settings.subheading %}
            <p style="text-align:{{ section.settings.text_align|default('center') }}; color:{{ section.settings.text_color|default('#616161') }}; max-width:600px; margin:0 auto 40px;">
                {{ section.settings.subheading }}
            </p>
        {% endif %}

        {% if section.blocks|length > 0 %}
            <div style="display:grid; grid-template-columns:repeat({{ section.settings.columns|default(3) }}, 1fr); gap:32px;">
                {% for block in section.blocks %}
                    {% if block.type == 'feature' %}
                        <div style="text-align:{{ section.settings.text_align|default('center') }};">
                            {% if block.settings.icon %}
                                <div style="font-size:36px; margin-bottom:12px;">{{ block.settings.icon }}</div>
                            {% endif %}
                            {% if block.settings.title %}
                                <h3 style="color:{{ section.settings.heading_color|default('#303030') }}; margin-bottom:8px; font-size:18px;">
                                    {{ block.settings.title }}
                                </h3>
                            {% endif %}
                            {% if block.settings.description %}
                                <p style="color:{{ section.settings.text_color|default('#616161') }}; line-height:1.6; font-size:14px;">
                                    {{ block.settings.description }}
                                </p>
                            {% endif %}
                        </div>
                    {% endif %}
                {% endfor %}
            </div>
        {% else %}
            <p style="text-align:center; color:#999;">Add feature blocks to populate this section.</p>
        {% endif %}
    </div>
</section>

{% schema %}
{
    "name": "Feature Columns",
    "description": "Highlight features or benefits in a multi-column layout",
    "icon": "columns",
    "settings": [
        {"type": "text", "id": "heading", "label": "Heading", "default": "Our Features"},
        {"type": "text", "id": "subheading", "label": "Subheading"},
        {"type": "select", "id": "columns", "label": "Columns", "default": "3",
         "options": [{"value": "2", "label": "2 Columns"}, {"value": "3", "label": "3 Columns"}, {"value": "4", "label": "4 Columns"}]},
        {"type": "select", "id": "text_align", "label": "Text Alignment", "default": "center",
         "options": [{"value": "left", "label": "Left"}, {"value": "center", "label": "Center"}]},
        {"type": "color", "id": "bg_color", "label": "Background Color", "default": "#ffffff"},
        {"type": "color", "id": "heading_color", "label": "Heading Color", "default": "#303030"},
        {"type": "color", "id": "text_color", "label": "Text Color", "default": "#616161"},
        {"type": "range", "id": "padding", "label": "Section Padding (px)", "min": 0, "max": 120, "step": 4, "default": 60}
    ],
    "blocks": [
        {
            "type": "feature",
            "name": "Feature",
            "settings": [
                {"type": "text", "id": "icon", "label": "Icon (emoji or symbol)", "default": "⚡"},
                {"type": "text", "id": "title", "label": "Title", "default": "Feature Title"},
                {"type": "textarea", "id": "description", "label": "Description", "default": "Describe this feature in a few sentences."}
            ]
        }
    ],
    "presets": [
        {
            "name": "Feature Columns",
            "settings": {"heading": "Our Features", "columns": "3"},
            "blocks": [
                {"type": "feature", "settings": {"icon": "⚡", "title": "Fast", "description": "Lightning-fast performance."}},
                {"type": "feature", "settings": {"icon": "🔒", "title": "Secure", "description": "Built with security in mind."}},
                {"type": "feature", "settings": {"icon": "📱", "title": "Responsive", "description": "Works on every device."}}
            ]
        }
    ]
}
{% endschema %}
