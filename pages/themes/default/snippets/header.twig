{# Header snippet - include with: {% include "@theme/snippets/header.twig" %} #}
<header class="page-header" style="padding: 2rem 0; border-bottom: 1px solid rgba(100, 255, 218, 0.1); margin-bottom: 2rem;">
    <h1>{{ page.title ?? 'Page' }}</h1>
    {% if page.subtitle is defined and page.subtitle %}
        <p style="color: var(--text-secondary);">{{ page.subtitle }}</p>
    {% endif %}
</header>
