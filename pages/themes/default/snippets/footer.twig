<footer class="site-footer">
    <div class="container">
        <div class="footer__inner">
            <p class="footer__copy">&copy; {{ "now"|date("Y") }} {{ config('app.name', 'ZephyrPHP') }}</p>
            {% if theme_settings is defined %}
            <ul class="footer__social">
                {% if theme_settings.social_twitter is defined and theme_settings.social_twitter %}
                    <li><a href="{{ theme_settings.social_twitter }}" target="_blank" rel="noopener">Twitter</a></li>
                {% endif %}
                {% if theme_settings.social_github is defined and theme_settings.social_github %}
                    <li><a href="{{ theme_settings.social_github }}" target="_blank" rel="noopener">GitHub</a></li>
                {% endif %}
                {% if theme_settings.social_linkedin is defined and theme_settings.social_linkedin %}
                    <li><a href="{{ theme_settings.social_linkedin }}" target="_blank" rel="noopener">LinkedIn</a></li>
                {% endif %}
            </ul>
            {% endif %}
        </div>
    </div>
</footer>
