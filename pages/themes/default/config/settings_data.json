                            "settings": {
                                "question": "What are the system requirements?",
                                "answer": "<p>ZephyrPHP requires PHP 8.1 or higher and Composer. It works with MySQL, PostgreSQL, or SQLite databases out of the box.</p>"
                            }
                        },
                        "faq_2": {
                            "type": "question",
                            "settings": {
                                "question": "How do I install ZephyrPHP?",
                                "answer": "<p>Run <code>composer create-project zephyrphp/starter my-project</code> and you're ready to go. The starter template comes with everything pre-configured.</p>"
                            }
                        },
                        "faq_3": {
                            "type": "question",
                            "settings": {
                                "question": "Does it include a CMS?",
                                "answer": "<p>Yes! The optional CMS module adds a full content management system with collections, page types, media management, and a Shopify-style visual theme builder.</p>"
                            }
                        },
                        "faq_4": {
                            "type": "question",
                            "settings": {
                                "question": "Can I use it for API-only projects?",
                                "answer": "<p>Absolutely. ZephyrPHP includes an API module with JSON responses, request validation, and middleware support. You can use it as a full-stack framework or API-only backend.</p>"
