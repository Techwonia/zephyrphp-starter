<section class="section-image-text" style="background:{{ section.settings.bg_color|default('#ffffff') }}; padding:{{ section.settings.padding|default(60) }}px 0;">
    <div class="container">
        <div style="display:grid; grid-template-columns:1fr 1fr; gap:40px; align-items:center;">
            {% set imgFirst = section.settings.image_position|default('left') == 'left' %}

            {% if imgFirst %}
            <div>
                {% if section.settings.image %}
                    <img src="/{{ section.settings.image }}" alt="{{ section.settings.heading|default('') }}" style="width:100%; border-radius:{{ section.settings.image_radius|default(8) }}px;">
                {% else %}
                    <div style="background:#f0f0f0; border-radius:{{ section.settings.image_radius|default(8) }}px; padding:80px; text-align:center; color:#999;">No image selected</div>
                {% endif %}
            </div>
            {% endif %}

            <div>
                {% if section.settings.heading %}
                    <h2 style="color:{{ section.settings.heading_color|default('#303030') }}; margin-bottom:16px;">{{ section.settings.heading }}</h2>
                {% endif %}
                {% if section.settings.text %}
                    <div style="color:{{ section.settings.text_color|default('#616161') }}; line-height:1.7;">{{ section.settings.text|raw }}</div>
                {% endif %}
                {% if section.settings.button_text %}
                    <a href="{{ section.settings.button_url|default('#') }}" style="display:inline-block; margin-top:20px; padding:10px 24px; background:{{ section.settings.button_color|default('#008060') }}; color:#fff; border-radius:6px; text-decoration:none;">
                        {{ section.settings.button_text }}
                    </a>
                {% endif %}
            </div>

            {% if not imgFirst %}
            <div>
                {% if section.settings.image %}
                    <img src="/{{ section.settings.image }}" alt="{{ section.settings.heading|default('') }}" style="width:100%; border-radius:{{ section.settings.image_radius|default(8) }}px;">
                {% else %}
                    <div style="background:#f0f0f0; border-radius:{{ section.settings.image_radius|default(8) }}px; padding:80px; text-align:center; color:#999;">No image selected</div>
                {% endif %}
            </div>
            {% endif %}
        </div>
    </div>
</section>

{% schema %}
{
    "name": "Image with Text",
    "description": "Side-by-side image and text content",
    "icon": "image-text",
    "settings": [
        {"type": "image", "id": "image", "label": "Image"},
        {"type": "text", "id": "heading", "label": "Heading", "default": "About Us"},
        {"type": "richtext", "id": "text", "label": "Text", "default": "<p>Tell your story here.</p>"},
        {"type": "text", "id": "button_text", "label": "Button Text"},
        {"type": "url", "id": "button_url", "label": "Button URL"},
        {"type": "color", "id": "button_color", "label": "Button Color", "default": "#008060"},
        {"type": "select", "id": "image_position", "label": "Image Position", "default": "left",
         "options": [{"value": "left", "label": "Left"}, {"value": "right", "label": "Right"}]},
        {"type": "range", "id": "image_radius", "label": "Image Border Radius (px)", "min": 0, "max": 24, "step": 2, "default": 8},
        {"type": "color", "id": "bg_color", "label": "Background Color", "default": "#ffffff"},
        {"type": "color", "id": "heading_color", "label": "Heading Color", "default": "#303030"},
        {"type": "color", "id": "text_color", "label": "Text Color", "default": "#616161"},
        {"type": "range", "id": "padding", "label": "Section Padding (px)", "min": 0, "max": 120, "step": 4, "default": 60}
    ],
    "presets": [
        {"name": "Image with Text", "settings": {"heading": "About Us", "text": "<p>Tell your story here.</p>"}}
    ]
}
{% endschema %}
