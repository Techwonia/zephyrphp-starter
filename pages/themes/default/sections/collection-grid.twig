<section class="section-collection-grid" style="background:{{ section.settings.bg_color|default('#ffffff') }}; padding:{{ section.settings.padding|default(60) }}px 0;">
    <div class="container">
        {% if section.settings.heading %}
            <h2 style="text-align:{{ section.settings.text_align|default('center') }}; color:{{ section.settings.heading_color|default('#303030') }}; margin-bottom:32px;">
                {{ section.settings.heading }}
            </h2>
        {% endif %}
        {% if section.settings.subheading %}
            <p style="text-align:{{ section.settings.text_align|default('center') }}; color:{{ section.settings.text_color|default('#616161') }}; max-width:600px; margin:0 auto 40px;">
                {{ section.settings.subheading }}
            </p>
        {% endif %}

        {% if section.settings.collection %}
            {% set items = collection(section.settings.collection, {per_page: section.settings.items_count|default(6), sort_dir: section.settings.sort_dir|default('DESC')}) %}

            {% if items.data|length > 0 %}
                <div style="display:grid; grid-template-columns:repeat({{ section.settings.columns|default(3) }}, 1fr); gap:{{ section.settings.gap|default(24) }}px;">
                    {% for item in items.data %}
                        <div style="background:{{ section.settings.card_bg|default('#fafafa') }}; border-radius:8px; overflow:hidden; border:1px solid #eee;">
                            {% if item.image is defined and item.image %}
                                <img src="/{{ item.image }}" alt="{{ item.title|default('') }}" style="width:100%; height:200px; object-fit:cover;">
                            {% endif %}
                            <div style="padding:20px;">
                                {% if item.title is defined %}
                                    <h3 style="margin:0 0 8px; color:{{ section.settings.heading_color|default('#303030') }}; font-size:18px;">{{ item.title }}</h3>
                                {% endif %}
                                {% if section.settings.show_excerpt and item.excerpt is defined %}
                                    <p style="color:{{ section.settings.text_color|default('#616161') }}; font-size:14px; margin:0;">{{ item.excerpt|slice(0, 120) }}...</p>
                                {% endif %}
                                {% if section.settings.show_link and item.slug is defined %}
                                    <a href="{{ item.slug }}" style="display:inline-block; margin-top:12px; color:{{ section.settings.link_color|default('#008060') }}; text-decoration:none; font-weight:500;">
                                        {{ section.settings.link_text|default('Read More') }} &rarr;
                                    </a>
                                {% endif %}
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% else %}
                <p style="text-align:center; color:#999; padding:40px 0;">No entries found in this collection.</p>
            {% endif %}
        {% else %}
            <p style="text-align:center; color:#999; padding:40px 0;">Select a collection to display.</p>
        {% endif %}
    </div>
</section>

{% schema %}
{
    "name": "Collection Grid",
    "description": "Display entries from a collection in a responsive grid layout",
    "icon": "grid",
    "settings": [
        {"type": "text", "id": "heading", "label": "Heading", "default": "Featured Items"},
        {"type": "text", "id": "subheading", "label": "Subheading"},
        {"type": "collection", "id": "collection", "label": "Collection"},
        {"type": "range", "id": "items_count", "label": "Items to Show", "min": 2, "max": 24, "step": 1, "default": 6},
        {"type": "select", "id": "columns", "label": "Columns", "default": "3",
         "options": [{"value": "2", "label": "2 Columns"}, {"value": "3", "label": "3 Columns"}, {"value": "4", "label": "4 Columns"}]},
        {"type": "select", "id": "sort_dir", "label": "Sort Order", "default": "DESC",
         "options": [{"value": "DESC", "label": "Newest First"}, {"value": "ASC", "label": "Oldest First"}]},
        {"type": "checkbox", "id": "show_excerpt", "label": "Show Excerpt", "default": true},
        {"type": "checkbox", "id": "show_link", "label": "Show Link", "default": true},
        {"type": "text", "id": "link_text", "label": "Link Text", "default": "Read More"},
        {"type": "color", "id": "link_color", "label": "Link Color", "default": "#008060"},
        {"type": "select", "id": "text_align", "label": "Header Alignment", "default": "center",
         "options": [{"value": "left", "label": "Left"}, {"value": "center", "label": "Center"}]},
        {"type": "range", "id": "gap", "label": "Card Gap (px)", "min": 8, "max": 48, "step": 4, "default": 24},
        {"type": "color", "id": "bg_color", "label": "Background Color", "default": "#ffffff"},
        {"type": "color", "id": "card_bg", "label": "Card Background", "default": "#fafafa"},
        {"type": "color", "id": "heading_color", "label": "Heading Color", "default": "#303030"},
        {"type": "color", "id": "text_color", "label": "Text Color", "default": "#616161"},
        {"type": "range", "id": "padding", "label": "Section Padding (px)", "min": 0, "max": 120, "step": 4, "default": 60}
    ],
    "presets": [
        {"name": "Collection Grid", "settings": {"heading": "Featured Items", "items_count": 6, "columns": "3"}}
    ]
}
{% endschema %}
