<section class="section-collection-grid" style="background:{{ section.settings.bg_color|default('#ffffff') }}; padding:{{ section.settings.padding|default(60) }}px 0;">
    <div class="container" style="max-width:1200px; margin:0 auto; padding:0 24px;">
        {% if section.settings.heading %}
            <h2 style="text-align:{{ section.settings.text_align|default('center') }}; color:{{ section.settings.heading_color|default('#303030') }}; margin-bottom:8px; font-size:{{ section.settings.heading_size|default(28) }}px;">
                {{ section.settings.heading }}
            </h2>
        {% endif %}
        {% if section.settings.subheading %}
            <p style="text-align:{{ section.settings.text_align|default('center') }}; color:{{ section.settings.text_color|default('#616161') }}; max-width:600px; margin:0 auto 40px; font-size:{{ section.settings.subheading_size|default(16) }}px;">
                {{ section.settings.subheading }}
            </p>
        {% endif %}

        {% if section.settings.collection %}
            {% set title_field = section.settings.title_field|default('title') %}
            {% set excerpt_field = section.settings.excerpt_field|default('') %}
            {% set image_field = section.settings.image_field|default('') %}
            {% set link_field = section.settings.link_field|default('slug') %}

            {% set items = collection(section.settings.collection, {per_page: section.settings.items_count|default(6), sort_dir: section.settings.sort_dir|default('DESC')}) %}

            {% if items.data|length > 0 %}
                <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax({{ section.settings.card_min_width|default(280) }}px, 1fr)); gap:{{ section.settings.gap|default(24) }}px;">
                    {% for item in items.data %}
                        <div style="background:{{ section.settings.card_bg|default('#fafafa') }}; border-radius:{{ section.settings.card_radius|default(8) }}px; overflow:hidden; border:1px solid {{ section.settings.card_border|default('#eeeeee') }};">
                            {% if image_field and attribute(item, image_field) is defined and attribute(item, image_field) %}
                                <div style="height:{{ section.settings.image_height|default(200) }}px; overflow:hidden;">
                                    <img src="/{{ attribute(item, image_field) }}" alt="{{ title_field ? attribute(item, title_field)|default('') : '' }}" style="width:100%; height:100%; object-fit:cover;">
                                </div>
                            {% endif %}
                            <div style="padding:{{ section.settings.card_padding|default(20) }}px;">
                                {% if title_field and attribute(item, title_field) is defined and attribute(item, title_field) %}
                                    <h3 style="margin:0 0 8px; color:{{ section.settings.heading_color|default('#303030') }}; font-size:{{ section.settings.title_size|default(18) }}px;">{{ attribute(item, title_field) }}</h3>
                                {% endif %}
                                {% if section.settings.show_excerpt and excerpt_field and attribute(item, excerpt_field) is defined and attribute(item, excerpt_field) %}
                                    <p style="color:{{ section.settings.text_color|default('#616161') }}; font-size:{{ section.settings.excerpt_size|default(14) }}px; margin:0; line-height:1.5;">{{ attribute(item, excerpt_field)|striptags|slice(0, section.settings.excerpt_length|default(120)) }}{% if attribute(item, excerpt_field)|length > section.settings.excerpt_length|default(120) %}...{% endif %}</p>
                                {% endif %}
                                {% if section.settings.show_link and link_field and attribute(item, link_field) is defined %}
                                    <a href="{{ attribute(item, link_field) }}" style="display:inline-block; margin-top:12px; color:{{ section.settings.link_color|default('#008060') }}; text-decoration:none; font-weight:500; font-size:{{ section.settings.link_size|default(14) }}px;">
                                        {{ section.settings.link_text|default('Read More') }} &rarr;
                                    </a>
                                {% endif %}
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% else %}
                <p style="text-align:center; color:#999; padding:40px 0;">No entries found in this collection.</p>
            {% endif %}
        {% else %}
            <p style="text-align:center; color:#999; padding:40px 0;">Select a collection to display.</p>
        {% endif %}
    </div>
</section>

{% schema %}
{
    "name": "Collection Grid",
    "description": "Display entries from a collection in a responsive grid layout",
    "icon": "grid",
    "settings": [
        {"type": "text", "id": "heading", "label": "Heading", "default": "Featured Items"},
        {"type": "text", "id": "subheading", "label": "Subheading"},
        {"type": "collection", "id": "collection", "label": "Collection"},

        {"type": "field_select", "id": "title_field", "label": "Title Field", "collection_setting": "collection", "default": "title"},
        {"type": "field_select", "id": "excerpt_field", "label": "Excerpt Field", "collection_setting": "collection", "default": ""},
        {"type": "field_select", "id": "image_field", "label": "Image Field", "collection_setting": "collection", "default": ""},
        {"type": "field_select", "id": "link_field", "label": "Link Field", "collection_setting": "collection", "default": "slug"},

        {"type": "range", "id": "items_count", "label": "Items to Show", "min": 2, "max": 24, "step": 1, "default": 6},
        {"type": "select", "id": "sort_dir", "label": "Sort Order", "default": "DESC",
         "options": [{"value": "DESC", "label": "Newest First"}, {"value": "ASC", "label": "Oldest First"}]},
        {"type": "checkbox", "id": "show_excerpt", "label": "Show Excerpt", "default": true},
        {"type": "checkbox", "id": "show_link", "label": "Show Link", "default": true},
        {"type": "text", "id": "link_text", "label": "Link Text", "default": "Read More"},

        {"type": "range", "id": "card_min_width", "label": "Card Min Width (px)", "min": 200, "max": 400, "step": 10, "default": 280},
        {"type": "range", "id": "image_height", "label": "Image Height (px)", "min": 100, "max": 400, "step": 10, "default": 200},
        {"type": "range", "id": "card_padding", "label": "Card Padding (px)", "min": 8, "max": 40, "step": 4, "default": 20},
        {"type": "range", "id": "card_radius", "label": "Card Radius (px)", "min": 0, "max": 24, "step": 2, "default": 8},
        {"type": "range", "id": "title_size", "label": "Title Size (px)", "min": 14, "max": 32, "step": 1, "default": 18},
        {"type": "range", "id": "excerpt_size", "label": "Excerpt Size (px)", "min": 12, "max": 18, "step": 1, "default": 14},
        {"type": "range", "id": "excerpt_length", "label": "Excerpt Length (chars)", "min": 50, "max": 300, "step": 10, "default": 120},
        {"type": "range", "id": "link_size", "label": "Link Size (px)", "min": 12, "max": 18, "step": 1, "default": 14},
        {"type": "range", "id": "heading_size", "label": "Heading Size (px)", "min": 18, "max": 48, "step": 1, "default": 28},
        {"type": "range", "id": "subheading_size", "label": "Subheading Size (px)", "min": 12, "max": 24, "step": 1, "default": 16},
        {"type": "range", "id": "gap", "label": "Card Gap (px)", "min": 8, "max": 48, "step": 4, "default": 24},

        {"type": "color", "id": "bg_color", "label": "Background Color", "default": "#ffffff"},
        {"type": "color", "id": "card_bg", "label": "Card Background", "default": "#fafafa"},
        {"type": "color", "id": "card_border", "label": "Card Border Color", "default": "#eeeeee"},
        {"type": "color", "id": "heading_color", "label": "Heading Color", "default": "#303030"},
        {"type": "color", "id": "text_color", "label": "Text Color", "default": "#616161"},
        {"type": "color", "id": "link_color", "label": "Link Color", "default": "#008060"},

        {"type": "select", "id": "text_align", "label": "Header Alignment", "default": "center",
         "options": [{"value": "left", "label": "Left"}, {"value": "center", "label": "Center"}]},
        {"type": "range", "id": "padding", "label": "Section Padding (px)", "min": 0, "max": 120, "step": 4, "default": 60}
    ],
    "presets": [
        {"name": "Collection Grid", "settings": {"heading": "Featured Items", "items_count": 6}}
    ]
}
{% endschema %}
