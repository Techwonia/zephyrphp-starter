<section class="section-newsletter" style="background:{{ section.settings.bg_color|default('#0a0e27') }}; padding:{{ section.settings.padding|default(60) }}px 0;">
    <div class="container" style="max-width:600px; margin:0 auto; text-align:center;">
        {% if section.settings.heading %}
            <h2 style="color:{{ section.settings.heading_color|default('#ffffff') }}; margin-bottom:12px;">
                {{ section.settings.heading }}
            </h2>
        {% endif %}
        {% if section.settings.subheading %}
            <p style="color:{{ section.settings.text_color|default('#8892b0') }}; margin-bottom:28px;">
                {{ section.settings.subheading }}
            </p>
        {% endif %}

        <form action="{{ section.settings.form_action|default('#') }}" method="{{ section.settings.form_method|default('POST') }}" style="display:flex; gap:12px; max-width:480px; margin:0 auto;">
            <input type="email" name="email" placeholder="{{ section.settings.placeholder|default('Enter your email') }}" required
                   style="flex:1; padding:12px 16px; border:1px solid {{ section.settings.input_border|default('#333') }}; border-radius:6px; background:{{ section.settings.input_bg|default('#16213e') }}; color:#fff; font-size:15px;">
            <button type="submit" style="padding:12px 24px; background:{{ section.settings.button_color|default('#008060') }}; color:#fff; border:none; border-radius:6px; font-weight:600; cursor:pointer; font-size:15px; white-space:nowrap;">
                {{ section.settings.button_text|default('Subscribe') }}
            </button>
        </form>

        {% if section.settings.disclaimer %}
            <p style="color:#666; font-size:12px; margin-top:16px;">{{ section.settings.disclaimer }}</p>
        {% endif %}
    </div>
</section>

{% schema %}
{
    "name": "Newsletter",
    "description": "Email newsletter signup form",
    "icon": "mail",
    "settings": [
        {"type": "text", "id": "heading", "label": "Heading", "default": "Stay Updated"},
        {"type": "text", "id": "subheading", "label": "Subheading", "default": "Subscribe to our newsletter for the latest updates."},
        {"type": "text", "id": "placeholder", "label": "Input Placeholder", "default": "Enter your email"},
        {"type": "text", "id": "button_text", "label": "Button Text", "default": "Subscribe"},
        {"type": "url", "id": "form_action", "label": "Form Action URL", "default": "#"},
        {"type": "text", "id": "disclaimer", "label": "Disclaimer Text"},
        {"type": "color", "id": "button_color", "label": "Button Color", "default": "#008060"},
        {"type": "color", "id": "bg_color", "label": "Background Color", "default": "#0a0e27"},
        {"type": "color", "id": "heading_color", "label": "Heading Color", "default": "#ffffff"},
        {"type": "color", "id": "text_color", "label": "Text Color", "default": "#8892b0"},
        {"type": "color", "id": "input_bg", "label": "Input Background", "default": "#16213e"},
        {"type": "color", "id": "input_border", "label": "Input Border", "default": "#333333"},
        {"type": "range", "id": "padding", "label": "Section Padding (px)", "min": 20, "max": 120, "step": 4, "default": 60}
    ],
    "presets": [
        {"name": "Newsletter", "settings": {"heading": "Stay Updated", "subheading": "Subscribe to our newsletter.", "button_text": "Subscribe"}}
    ]
}
{% endschema %}
