<section class="section-collection-list" style="background:{{ section.settings.bg_color|default('#ffffff') }}; padding:{{ section.settings.padding|default(60) }}px 0;">
    <div class="container" style="max-width:{{ section.settings.max_width|default(900) }}px; margin:0 auto; padding:0 24px;">
        {% if section.settings.heading %}
            <h2 style="color:{{ section.settings.heading_color|default('#303030') }}; margin-bottom:24px; font-size:{{ section.settings.heading_size|default(24) }}px;">
                {{ section.settings.heading }}
            </h2>
        {% endif %}

        {% if section.settings.collection %}
            {% set title_field = section.settings.title_field|default('title') %}
            {% set excerpt_field = section.settings.excerpt_field|default('') %}
            {% set image_field = section.settings.image_field|default('') %}
            {% set link_field = section.settings.link_field|default('slug') %}

            {% set items = collection(section.settings.collection, {per_page: section.settings.items_count|default(10), sort_dir: section.settings.sort_dir|default('DESC')}) %}

            {% if items.data|length > 0 %}
                <div style="display:flex; flex-direction:column; gap:{{ section.settings.gap|default(0) }}px;">
                    {% for item in items.data %}
                        <div style="display:flex; gap:{{ section.settings.row_gap|default(16) }}px; align-items:center; padding:{{ section.settings.row_padding|default(16) }}px;{% if section.settings.row_radius > 0 %} border-radius:{{ section.settings.row_radius }}px; margin-bottom:{{ section.settings.gap|default(0) }}px; border:1px solid {{ section.settings.border_color|default('#eeeeee') }};{% else %} border-bottom:1px solid {{ section.settings.border_color|default('#eeeeee') }};{% endif %}{% if section.settings.row_bg %} background:{{ section.settings.row_bg }};{% endif %}">
                            {% if section.settings.show_image and image_field and attribute(item, image_field) is defined and attribute(item, image_field) %}
                                <img src="/{{ attribute(item, image_field) }}" alt="{{ title_field ? attribute(item, title_field)|default('') : '' }}" style="width:{{ section.settings.image_size|default(80) }}px; height:{{ section.settings.image_size|default(80) }}px; object-fit:cover; border-radius:{{ section.settings.image_radius|default(6) }}px; flex-shrink:0;">
                            {% endif %}
                            <div style="flex:1; min-width:0;">
                                {% if title_field and attribute(item, title_field) is defined and attribute(item, title_field) %}
                                    <h3 style="margin:0 0 4px; color:{{ section.settings.heading_color|default('#303030') }}; font-size:{{ section.settings.title_size|default(16) }}px;">{{ attribute(item, title_field) }}</h3>
                                {% endif %}
                                {% if section.settings.show_excerpt and excerpt_field and attribute(item, excerpt_field) is defined and attribute(item, excerpt_field) %}
                                    <p style="margin:0; color:{{ section.settings.text_color|default('#616161') }}; font-size:{{ section.settings.excerpt_size|default(14) }}px; line-height:1.4;">{{ attribute(item, excerpt_field)|striptags|slice(0, section.settings.excerpt_length|default(150)) }}{% if attribute(item, excerpt_field)|length > section.settings.excerpt_length|default(150) %}...{% endif %}</p>
                                {% endif %}
                            </div>
                            {% if section.settings.show_link and link_field and attribute(item, link_field) is defined %}
                                <a href="{{ attribute(item, link_field) }}" style="color:{{ section.settings.link_color|default('#008060') }}; text-decoration:none; font-weight:500; white-space:nowrap; font-size:{{ section.settings.link_size|default(14) }}px;">
                                    {{ section.settings.link_text|default('View') }} &rarr;
                                </a>
                            {% endif %}
                        </div>
                    {% endfor %}
                </div>
            {% else %}
                <p style="text-align:center; color:#999; padding:40px 0;">No entries found.</p>
            {% endif %}
        {% else %}
            <p style="text-align:center; color:#999; padding:40px 0;">Select a collection to display.</p>
        {% endif %}
    </div>
</section>

{% schema %}
{
    "name": "Collection List",
    "description": "Display entries from a collection in a list/row layout",
    "icon": "list",
    "settings": [
        {"type": "text", "id": "heading", "label": "Heading", "default": "Latest Entries"},
        {"type": "collection", "id": "collection", "label": "Collection"},

        {"type": "field_select", "id": "title_field", "label": "Title Field", "collection_setting": "collection", "default": "title"},
        {"type": "field_select", "id": "excerpt_field", "label": "Excerpt Field", "collection_setting": "collection", "default": ""},
        {"type": "field_select", "id": "image_field", "label": "Image Field", "collection_setting": "collection", "default": ""},
        {"type": "field_select", "id": "link_field", "label": "Link Field", "collection_setting": "collection", "default": "slug"},

        {"type": "range", "id": "items_count", "label": "Items to Show", "min": 1, "max": 20, "step": 1, "default": 10},
        {"type": "select", "id": "sort_dir", "label": "Sort Order", "default": "DESC",
         "options": [{"value": "DESC", "label": "Newest First"}, {"value": "ASC", "label": "Oldest First"}]},
        {"type": "checkbox", "id": "show_image", "label": "Show Image", "default": true},
        {"type": "checkbox", "id": "show_excerpt", "label": "Show Excerpt", "default": true},
        {"type": "checkbox", "id": "show_link", "label": "Show Link", "default": true},
        {"type": "text", "id": "link_text", "label": "Link Text", "default": "View"},

        {"type": "range", "id": "image_size", "label": "Image Size (px)", "min": 40, "max": 160, "step": 8, "default": 80},
        {"type": "range", "id": "image_radius", "label": "Image Radius (px)", "min": 0, "max": 50, "step": 2, "default": 6},
        {"type": "range", "id": "row_padding", "label": "Row Padding (px)", "min": 8, "max": 32, "step": 4, "default": 16},
        {"type": "range", "id": "row_gap", "label": "Content Gap (px)", "min": 8, "max": 32, "step": 4, "default": 16},
        {"type": "range", "id": "title_size", "label": "Title Size (px)", "min": 14, "max": 24, "step": 1, "default": 16},
        {"type": "range", "id": "excerpt_size", "label": "Excerpt Size (px)", "min": 12, "max": 16, "step": 1, "default": 14},
        {"type": "range", "id": "excerpt_length", "label": "Excerpt Length (chars)", "min": 50, "max": 300, "step": 10, "default": 150},
        {"type": "range", "id": "link_size", "label": "Link Size (px)", "min": 12, "max": 16, "step": 1, "default": 14},
        {"type": "range", "id": "max_width", "label": "Max Width (px)", "min": 600, "max": 1200, "step": 50, "default": 900},
        {"type": "range", "id": "gap", "label": "Row Spacing (px)", "min": 0, "max": 16, "step": 2, "default": 0},
        {"type": "range", "id": "row_radius", "label": "Row Radius (px)", "min": 0, "max": 16, "step": 2, "default": 0},

        {"type": "color", "id": "bg_color", "label": "Background Color", "default": "#ffffff"},
        {"type": "color", "id": "row_bg", "label": "Row Background", "default": ""},
        {"type": "color", "id": "heading_color", "label": "Heading Color", "default": "#303030"},
        {"type": "color", "id": "text_color", "label": "Text Color", "default": "#616161"},
        {"type": "color", "id": "link_color", "label": "Link Color", "default": "#008060"},
        {"type": "color", "id": "border_color", "label": "Border Color", "default": "#eeeeee"},
        {"type": "range", "id": "heading_size", "label": "Heading Size (px)", "min": 18, "max": 36, "step": 1, "default": 24},
        {"type": "range", "id": "padding", "label": "Section Padding (px)", "min": 0, "max": 120, "step": 4, "default": 60}
    ],
    "presets": [
        {"name": "Collection List", "settings": {"heading": "Latest Entries", "items_count": 10}}
    ]
}
{% endschema %}
