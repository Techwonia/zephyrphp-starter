<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">

    <title>{% block title %}{{ seo.title ?? page.title ?? config('app.name', 'ZephyrPHP') }}{% endblock %}</title>

    {% if seo.description is defined and seo.description %}
    <meta name="description" content="{{ seo.description }}">
    {% endif %}

    {% if seo.image is defined and seo.image %}
    <meta property="og:image" content="/{{ seo.image }}">
    {% endif %}

    {{ load_assets('app') }}
    {{ render_css() }}

    {% block styles %}{% endblock %}
</head>
<body>
    <nav class="navbar">
        <div class="container">
            <a href="/" class="navbar-brand">
                <span class="brand-icon">&#9889;</span>
                {{ config('app.name', 'ZephyrPHP') }}
            </a>
            <ul class="nav-menu">
                <li><a href="/" class="nav-link">Home</a></li>
                {% block nav_items %}{% endblock %}
                {% set _auth = auth() %}
                {% if _auth and _auth.check %}
                    <li><a href="/cms" class="nav-link">CMS</a></li>
                    <li><a href="/logout" class="nav-link">Logout</a></li>
                {% else %}
                    <li><a href="/login" class="nav-link">Login</a></li>
                {% endif %}
            </ul>
        </div>
    </nav>

    <main class="main-content">
        <div class="container">
            {% block content %}{% endblock %}
        </div>
    </main>

    <footer class="footer">
        <div class="container">
            <p>&copy; {{ "now"|date("Y") }} {{ config('app.name', 'ZephyrPHP') }}</p>
        </div>
    </footer>

    {{ render_js() }}
    {% block scripts %}{% endblock %}
</body>
</html>
