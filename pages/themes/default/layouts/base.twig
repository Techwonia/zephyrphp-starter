<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">

    <title>{% block title %}{{ seo.title ?? page.title ?? config('app.name', 'ZephyrPHP') }}{% endblock %}</title>

    {% if seo is defined and seo.description is defined and seo.description %}
    <meta name="description" content="{{ seo.description }}">
    {% endif %}
    {% if seo is defined and seo.image is defined and seo.image %}
    <meta property="og:image" content="/{{ seo.image }}">
    {% endif %}
    {% block meta %}{% endblock %}

    {# Load core app assets #}
    {{ load_assets('app') }}
    {{ render_css() }}

    {% block styles %}{% endblock %}
</head>
<body>
    {# Preview banner #}
    {% if is_theme_preview is defined and is_theme_preview %}
    <div style="background: #FFB800; color: #303030; text-align: center; padding: 8px; font-size: 14px; font-weight: 600;">
        Theme Preview: {{ preview_theme_slug }} &mdash;
        <a href="/cms/themes" style="color: #303030; text-decoration: underline;">Back to Themes</a>
    </div>
    {% endif %}

    {# Main navigation #}
    <nav class="navbar">
        <div class="container">
            <a href="/" class="navbar-brand">
                <span class="brand-icon">&#9889;</span>
                {{ config('app.name', 'ZephyrPHP') }}
            </a>
            <ul class="nav-menu">
                <li><a href="/" class="nav-link">Home</a></li>
                {% block nav_items %}{% endblock %}
                {% set _auth = auth() %}
                {% if _auth and _auth.check %}
                    <li><a href="/cms" class="nav-link">CMS</a></li>
                    <li><a href="/logout" class="nav-link">Logout</a></li>
                {% else %}
                    <li><a href="/login" class="nav-link">Login</a></li>
                {% endif %}
            </ul>
        </div>
    </nav>

    {# Flash messages #}
    {% if flash('success') %}
        <div class="container" style="margin-top: var(--spacing-sm);">
            <div class="alert alert-success">{{ flash('success') }}</div>
        </div>
    {% endif %}
    {% if flash('error') %}
        <div class="container" style="margin-top: var(--spacing-sm);">
            <div class="alert alert-error">{{ flash('error') }}</div>
        </div>
    {% endif %}

    {# Main content area #}
    <main class="main-content">
        {% block body %}
        {% if use_sections is defined and use_sections and sections_html is defined %}
            {{ sections_html|raw }}
        {% else %}
        <div class="container">
            {% block content %}{% endblock %}
        </div>
        {% endif %}
        {% endblock %}
    </main>

    {# Footer #}
    <footer class="footer">
        <div class="container">
            <p>&copy; {{ "now"|date("Y") }} {{ config('app.name', 'ZephyrPHP') }}</p>
        </div>
    </footer>

    {{ render_js() }}
    {% block scripts %}{% endblock %}
</body>
</html>
