<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="csrf-token" content="{{ csrf_token() }}">
    <title>Reset Password — {{ config('app.name', 'ZephyrPHP') }}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --bg: #0a0a0a;
            --bg-input: #1a1a1a;
            --border: rgba(255,255,255,0.08);
            --border-focus: rgba(6,182,212,0.5);
            --text: #ededed;
            --text-2: #888;
            --text-3: #555;
            --primary: #06b6d4;
            --primary-light: #22d3ee;
            --error: #ef4444;
            --success: #22c55e;
            --font: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        }

        body {
            font-family: var(--font);
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
            margin: 0;
            -webkit-font-smoothing: antialiased;
        }

        /* ── Split Layout ── */
        .login-layout {
            display: grid;
            grid-template-columns: 1fr 1fr;
            min-height: 100vh;
        }

        /* ── Left Panel — Neon Grid ── */
        .login-left {
            position: relative;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
            border-right: 1px solid var(--border);
        }

        .login-left::before {
            content: '';
            position: absolute;
            inset: 0;
            background-image:
                linear-gradient(var(--border) 1px, transparent 1px),
                linear-gradient(90deg, var(--border) 1px, transparent 1px);
            background-size: 48px 48px;
            opacity: 0.5;
        }

        @keyframes neon-v {
            0%   { background-position: 0 -100%; }
            100% { background-position: 0 200%; }
        }

        @keyframes neon-h {
            0%   { background-position: -100% 0; }
            100% { background-position: 200% 0; }
        }

        .neon-line-v {
            position: absolute;
            top: 0;
            bottom: 0;
            width: 1px;
            background: var(--border);
            overflow: hidden;
        }

        .neon-line-v::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(to bottom, transparent 30%, rgba(6,182,212,0.1) 40%, rgba(6,182,212,0.4) 48%, rgba(6,182,212,0.7) 50%, rgba(6,182,212,0.4) 52%, rgba(6,182,212,0.1) 60%, transparent 70%);
            background-size: 100% 300%;
            animation: neon-v 9s ease-in-out infinite;
        }

        .neon-line-v::before {
            content: '';
            position: absolute;
            top: 0; bottom: 0;
            left: -6px; width: 13px;
            background: linear-gradient(to bottom, transparent 30%, rgba(6,182,212,0.0) 42%, rgba(6,182,212,0.12) 49%, rgba(6,182,212,0.0) 56%, transparent 70%);
            background-size: 100% 300%;
            animation: neon-v 9s ease-in-out infinite;
            filter: blur(6px);
        }

        .neon-line-v:nth-child(1) { left: 25%; }
        .neon-line-v:nth-child(2) { left: 50%; }
        .neon-line-v:nth-child(2)::after, .neon-line-v:nth-child(2)::before { animation-delay: -3s; }
        .neon-line-v:nth-child(3) { left: 75%; }
        .neon-line-v:nth-child(3)::after, .neon-line-v:nth-child(3)::before { animation-delay: -6s; }

        .neon-line-h {
            position: absolute;
            left: 0;
            right: 0;
            height: 1px;
            background: var(--border);
            overflow: hidden;
        }

        .neon-line-h::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(to right, transparent 30%, rgba(6,182,212,0.1) 40%, rgba(6,182,212,0.4) 48%, rgba(6,182,212,0.7) 50%, rgba(6,182,212,0.4) 52%, rgba(6,182,212,0.1) 60%, transparent 70%);
            background-size: 300% 100%;
            animation: neon-h 11s ease-in-out infinite;
        }

        .neon-line-h::before {
            content: '';
            position: absolute;
            left: 0; right: 0;
            top: -6px; height: 13px;
            background: linear-gradient(to right, transparent 30%, rgba(6,182,212,0.0) 42%, rgba(6,182,212,0.12) 49%, rgba(6,182,212,0.0) 56%, transparent 70%);
            background-size: 300% 100%;
            animation: neon-h 11s ease-in-out infinite;
            filter: blur(6px);
        }

        .neon-line-h:nth-child(4) { top: 33%; }
        .neon-line-h:nth-child(5) { top: 66%; }
        .neon-line-h:nth-child(5)::after, .neon-line-h:nth-child(5)::before { animation-delay: -4s; }

        @keyframes circle-glow {
            0%, 100% { border-color: var(--border); box-shadow: none; }
            50% { border-color: rgba(6,182,212,0.25); box-shadow: 0 0 16px rgba(6,182,212,0.1); }
        }

        .neon-circle {
            position: absolute;
            width: 80px;
            height: 80px;
            border: 1px solid var(--border);
            border-radius: 50%;
            transform: translate(-50%, -50%);
            animation: circle-glow 7s ease-in-out infinite;
        }

        .neon-circle:nth-child(6) { top: 33%; left: 25%; }
        .neon-circle:nth-child(7) { top: 66%; left: 75%; animation-delay: -3s; }

        .left-content {
            position: relative;
            z-index: 1;
            text-align: center;
            padding: 48px;
            max-width: 400px;
        }

        .left-brand {
            font-size: 2.5rem;
            margin-bottom: 16px;
        }

        .left-title {
            font-size: 1.5rem;
            font-weight: 700;
            letter-spacing: -0.02em;
            margin-bottom: 8px;
        }

        .left-desc {
            font-size: 0.9rem;
            color: var(--text-2);
            line-height: 1.6;
        }

        /* ── Right Panel — Form ── */
        .login-right {
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 48px;
        }

        .login-form-wrap {
            width: 100%;
            max-width: 380px;
        }

        .login-title {
            font-size: 1.5rem;
            font-weight: 700;
            margin-bottom: 4px;
        }

        .login-subtitle {
            color: var(--text-2);
            font-size: 0.875rem;
            margin-bottom: 32px;
        }

        .form-group { margin-bottom: 20px; }

        .form-group label {
            display: block;
            font-size: 0.8125rem;
            font-weight: 500;
            color: var(--text-2);
            margin-bottom: 6px;
        }

        .form-control {
            width: 100%;
            padding: 11px 14px;
            border: 1px solid var(--border);
            border-radius: 8px;
            font-size: 0.9rem;
            font-family: var(--font);
            color: var(--text);
            background: var(--bg-input);
            transition: border-color 0.15s, box-shadow 0.15s;
            outline: none;
        }

        .form-control:focus {
            border-color: var(--border-focus);
            box-shadow: 0 0 0 3px rgba(6,182,212,0.08);
        }

        .form-control::placeholder { color: var(--text-3); }
        .form-control.is-invalid { border-color: var(--error); }
        .invalid-feedback { color: var(--error); font-size: 0.8rem; margin-top: 4px; }

        .btn-submit {
            width: 100%;
            padding: 12px;
            background: var(--primary);
            color: #000;
            border: none;
            border-radius: 8px;
            font-size: 0.9rem;
            font-weight: 600;
            font-family: var(--font);
            cursor: pointer;
            transition: background 0.15s;
            margin-top: 8px;
        }

        .btn-submit:hover { background: var(--primary-light); }

        .alert {
            padding: 10px 14px;
            border-radius: 8px;
            font-size: 0.8125rem;
            margin-bottom: 20px;
        }

        .alert--error { background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.2); color: var(--error); }
        .alert--success { background: rgba(34,197,94,0.1); border: 1px solid rgba(34,197,94,0.2); color: var(--success); }

        .password-hint {
            font-size: 0.75rem;
            color: var(--text-3);
            margin-top: 6px;
            line-height: 1.5;
        }

        .back-link {
            display: block;
            text-align: center;
            margin-top: 24px;
            font-size: 0.8125rem;
            color: var(--text-2);
            text-decoration: none;
            transition: color 0.15s;
        }

        .back-link:hover { color: var(--primary); }

        .login-footer {
            text-align: center;
            margin-top: 32px;
            font-size: 0.75rem;
            color: var(--text-3);
        }

        @media (max-width: 768px) {
            .login-layout { grid-template-columns: 1fr; }
            .login-left { display: none; }
            .login-right { min-height: 100vh; }
        }
    </style>
</head>
<body>

<div class="login-layout">
    <!-- Left — Neon Grid -->
    <div class="login-left" aria-hidden="true">
        <div class="neon-line-v"></div>
        <div class="neon-line-v"></div>
        <div class="neon-line-v"></div>
        <div class="neon-line-h"></div>
        <div class="neon-line-h"></div>
        <div class="neon-circle"></div>
        <div class="neon-circle"></div>

        <div class="left-content">
            <div class="left-brand">⚡</div>
            <h1 class="left-title">{{ config('app.name', 'ZephyrPHP') }}</h1>
            <p class="left-desc">Visual page builder, theme customizer, and AI content tools — all from one admin panel.</p>
        </div>
    </div>

    <!-- Right — Reset Password Form -->
    <main class="login-right">
        <div class="login-form-wrap">
            <h2 class="login-title">Reset password</h2>
            <p class="login-subtitle">Choose a new password for your account</p>

            {% if flash('errors').token is defined %}
                <div class="alert alert--error">{{ flash('errors').token }}</div>
            {% endif %}

            <form method="POST" action="/zephyrphp/auth/reset-password">
                {{ csrf_field() | raw }}

                <input type="hidden" name="token" value="{{ token }}">
                <input type="hidden" name="email" value="{{ email }}">

                <div class="form-group">
                    <label for="password">New Password</label>
                    <input type="password" id="password" name="password"
                           class="form-control{% if flash('errors').password is defined %} is-invalid{% endif %}"
                           placeholder="Enter new password" required autofocus>
                    {% if flash('errors').password is defined %}
                        <div class="invalid-feedback">{{ flash('errors').password }}</div>
                    {% endif %}
                    <p class="password-hint">Min 8 characters, at least 1 uppercase, 1 lowercase, and 1 number.</p>
                </div>

                <div class="form-group">
                    <label for="password_confirmation">Confirm Password</label>
                    <input type="password" id="password_confirmation" name="password_confirmation"
                           class="form-control{% if flash('errors').password_confirmation is defined %} is-invalid{% endif %}"
                           placeholder="Confirm new password" required>
                    {% if flash('errors').password_confirmation is defined %}
                        <div class="invalid-feedback">{{ flash('errors').password_confirmation }}</div>
                    {% endif %}
                </div>

                <button type="submit" class="btn-submit">Reset Password</button>
            </form>

            <a href="/zephyrphp/auth/login" class="back-link">Back to sign in</a>

            <p class="login-footer">&copy; {{ "now"|date("Y") }} {{ config('app.name', 'ZephyrPHP') }}</p>
        </div>
    </main>
</div>

</body>
</html>
