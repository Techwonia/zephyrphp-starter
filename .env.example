# ZephyrPHP Configuration

# Application (configured via setup wizard)
APP_NAME=ZephyrPHP
ENV=dev
APP_DEBUG=true
APP_KEY=

# Admin Panel URL (e.g. yoursite.com/admin)
ADMIN_PATH=admin

# Database (configured via setup wizard)
DB_CONNECTION=pdo_mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=zephyrphp
DB_USERNAME=root
DB_PASSWORD=
