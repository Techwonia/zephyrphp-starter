# ZephyrPHP Configuration

# Application
APP_NAME=ZephyrPHP
APP_DEBUG=true # WARNING: Set to false in production!
ENV=dev

# Security (auto-generated on first boot if empty)
APP_KEY=

# Views
VIEWS_PATH=/pages

# Database
DB_CONNECTION=pdo_mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=zephyrphp
DB_USERNAME=root # WARNING: Change credentials for production!
DB_PASSWORD= # WARNING: Change credentials for production!

# Auth
AUTH_HOME=/cms
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_SECURE=false
SESSION_HTTPONLY=true
SESSION_SAMESITE=Lax
# Set SESSION_SECURE=true in production with HTTPS

# CMS
CMS_THEME=hello
