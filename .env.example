# ZephyrPHP Configuration

# Application
APP_NAME=ZephyrPHP
APP_DEBUG=true
ENV=dev

# Security (auto-generated on first boot if empty)
APP_KEY=

# Admin Panel Path (change to move your admin panel URL)
ADMIN_PATH=admin

# Database (configured via setup wizard)
DB_CONNECTION=pdo_mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=zephyrphp
DB_USERNAME=root
DB_PASSWORD=
