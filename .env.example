# ZephyrPHP Configuration

# Application
APP_NAME=ZephyrPHP
APP_DEBUG=true
ENV=dev
APP_URL=http://localhost
APP_TIMEZONE=UTC
APP_LOCALE=en

# Security (auto-generated on setup completion if empty)
APP_KEY=

# Admin Panel Path (change to move your admin panel URL)
ADMIN_PATH=admin

# Views / Templates
VIEWS_PATH=pages

# Auth
AUTH_HOME=/

# Database (configured via setup wizard)
DB_CONNECTION=pdo_mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=zephyrphp
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4

# Cache
CACHE_DRIVER=file
CACHE_PREFIX=zephyr_

# Session
SESSION_LIFETIME=120

# Security Headers
CSP_ENABLED=true
CSP_LEVEL=moderate
CSP_USE_NONCES=true
HSTS_ENABLED=true
RATE_LIMIT_ENABLED=true
